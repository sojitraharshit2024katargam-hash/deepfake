<script>
(function(){
'use strict';

/* ── Cursor ── */
var CUR=document.getElementById('CUR'),CUR2=document.getElementById('CUR2'),mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;CUR.style.left=mx+'px';CUR.style.top=my+'px';});
(function L(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;CUR2.style.left=rx+'px';CUR2.style.top=ry+'px';requestAnimationFrame(L);})();
document.querySelectorAll('a,button,.hist-card,.stcell,.res-item').forEach(function(el){
  el.addEventListener('mouseenter',function(){CUR2.style.width='52px';CUR2.style.height='52px';CUR2.style.borderColor='rgba(201,169,110,.9)';CUR2.style.background='rgba(201,169,110,.05)';});
  el.addEventListener('mouseleave',function(){CUR2.style.width='32px';CUR2.style.height='32px';CUR2.style.borderColor='rgba(201,169,110,.4)';CUR2.style.background='transparent';});
});

/* ── Uplink flicker ── */
setInterval(function(){document.getElementById('uplinkTxt').textContent=['ACTIVE','STABLE','NOMINAL'][Math.floor(Math.random()*3)];},5200);

/* ── Counters ── */
function animCnt(el){
  var v=parseFloat(el.dataset.v),isF=String(v).includes('.');
  var dur=1600,s=performance.now();
  (function t(now){var p=Math.min(1,(now-s)/dur),e=1-Math.pow(1-p,4);el.textContent=isF?(v*e).toFixed(1):Math.round(v*e);if(p<1)requestAnimationFrame(t);})(performance.now());
}
var cio=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){animCnt(x.target);cio.unobserve(x.target);}});},{threshold:.4});
document.querySelectorAll('.cnt').forEach(function(el){cio.observe(el);});

/* ── Toast ── */
var TW=document.getElementById('TW');
function toast(h,p,ic,col){
  var el=document.createElement('div');el.className='toastx';
  el.innerHTML='<div class="t-ic" style="'+(col?'color:'+col+';border-color:'+col+'44':'')+'"><i class="fa-solid '+(ic||'fa-circle-info')+'"></i></div><div><div class="t-h">'+h+'</div><div class="t-p">'+p+'</div></div><button class="t-x"><i class="fa-solid fa-xmark"></i></button>';
  el.querySelector('.t-x').addEventListener('click',function(){el.remove();});
  TW.appendChild(el);setTimeout(function(){if(el.isConnected)el.remove();},5000);
}

/* ── Input ── */
var emailInput=document.getElementById('emailInput'),analyzeBtn=document.getElementById('analyzeBtn');
var charCount=document.getElementById('charCount'),inputStatus=document.getElementById('inputStatus');
emailInput.addEventListener('input',function(){
  var len=emailInput.value.length;
  charCount.textContent=len;
  if(len===0){inputStatus.textContent='Waiting for input';inputStatus.style.color='var(--c4)';analyzeBtn.disabled=true;}
  else if(len<50){inputStatus.textContent='Add more content';inputStatus.style.color='var(--warn)';analyzeBtn.disabled=true;}
  else{inputStatus.textContent='Ready to scan';inputStatus.style.color='var(--ok)';analyzeBtn.disabled=false;}
});

/* ── Error ── */
function showErr(m){var b=document.getElementById('errBox');document.getElementById('errTxt').textContent=m;b.classList.add('show');}
function clearErr(){document.getElementById('errBox').classList.remove('show');}

/* ── Ring animation ── */
function animateRing(score){
  var fg=document.getElementById('ringFg');
  var circumference=251.3;
  var offset=circumference-(score/100)*circumference;
  fg.style.strokeDashoffset=offset;
  fg.style.stroke=score>=70?'var(--ok)':score>=40?'var(--warn)':'var(--red)';
  document.getElementById('ringNum').textContent=score+'%';
  var riskEl=document.getElementById('scoreRisk');
  var verdictEl=document.getElementById('scoreVerdict');
  if(score>=70){riskEl.textContent='LOW RISK';riskEl.className='score-risk low';verdictEl.innerHTML='Email appears<br><em style="font-style:italic;color:var(--ok)">legitimate</em>';}
  else if(score>=40){riskEl.textContent='MEDIUM RISK';riskEl.className='score-risk med';verdictEl.innerHTML='Suspicious<br><em style="font-style:italic;color:var(--warn)">patterns found</em>';}
  else{riskEl.textContent='HIGH RISK';riskEl.className='score-risk high';verdictEl.innerHTML='Likely<br><em style="font-style:italic;color:var(--red)">malicious</em>';}
  document.getElementById('riskLbl').textContent=score>=70?'LOW':score>=40?'MEDIUM':'HIGH';
  document.getElementById('riskLbl').style.color=score>=70?'var(--ok)':score>=40?'var(--warn)':'var(--red)';
  document.getElementById('verdictKbd').textContent=score>=70?'SAFE':score>=40?'SUSPICIOUS':'DANGER';
  document.getElementById('verdictKbd').style.color=score>=70?'var(--ok)':score>=40?'var(--warn)':'var(--red)';
}

/* ── Show results ── */
function showResults(result){
  // Animate ring
  animateRing(result.securityScore||75);
  // Result dots
  function setDot(id,sev){
    var dot=document.getElementById(id);
    if(sev==='Danger'){dot.className='res-dot bad';}
    else if(sev==='Warning'){dot.className='res-dot warn';}
    else{dot.className='res-dot ok';}
  }
  function setRes(id,badgeId,dotId,msg,sev){
    document.getElementById(id).textContent=msg||'No issues detected.';
    setDot(dotId,sev);
    var badge=document.getElementById(badgeId);
    var cls=sev==='Danger'?'bad':sev==='Warning'?'warn':'ok';
    badge.className='res-badge '+cls;
    badge.innerHTML='<i class="fa-solid fa-'+(sev==='Danger'?'times-circle':sev==='Warning'?'exclamation-triangle':'check-circle')+'"></i>'+sev;
    badge.style.display='inline-flex';
  }
  setRes('spfResult','spfBadge','spfDot','Spoofing analysis complete.','Safe');
  setRes('phishResult','phishBadge','phishDot','Phishing analysis complete.','Safe');
  setRes('malResult','malBadge','malDot','No malicious content detected.','Safe');
  setRes('authResult','authBadge','authDot','Auth alignment checked.','Safe');
  if(result.findings){
    result.findings.forEach(function(f){
      if(f.type==='Spoofing')setRes('spfResult','spfBadge','spfDot',f.message,f.severity);
      if(f.type==='Phishing')setRes('phishResult','phishBadge','phishDot',f.message,f.severity);
      if(f.type==='Malware')setRes('malResult','malBadge','malDot',f.message,f.severity);
      if(f.type==='Auth')setRes('authResult','authBadge','authDot',f.message,f.severity);
    });
  }
  // Findings list
  var fl=document.getElementById('findingsList');
  fl.innerHTML='';
  if(result.findings&&result.findings.length){
    result.findings.forEach(function(f){
      var cls=f.severity==='Danger'?'bad':f.severity==='Warning'?'warn':'ok';
      var ic=f.severity==='Danger'?'fa-times-circle':f.severity==='Warning'?'fa-exclamation-triangle':'fa-check-circle';
      fl.innerHTML+='<div class="find-row"><div class="find-ico"><i class="fa-solid '+ic+'" style="color:'+(cls==='bad'?'var(--red)':cls==='warn'?'var(--warn)':'var(--ok)')+'"></i></div><div><div class="find-h">'+f.type+'</div><div class="find-p">'+f.message+'</div></div></div>';
    });
  } else {
    fl.innerHTML='<div class="find-row"><div class="find-ico"><i class="fa-solid fa-check-circle" style="color:var(--ok)"></i></div><div><div class="find-h">Clean</div><div class="find-p">No threat indicators found in this email.</div></div></div>';
  }
  // Breakdown
  var bl=document.getElementById('breakdownList');
  bl.innerHTML='';
  if(result.scoreBreakdown&&result.scoreBreakdown.length){
    result.scoreBreakdown.forEach(function(b){
      var pos=b.points>=0;
      var pct=Math.min(100,Math.abs(b.points));
      bl.innerHTML+='<div class="bk-row"><div class="bk-label">'+b.reason+'</div><div class="bk-bar"><div class="bk-bar-fill '+(pos?'pos':'neg')+'" style="width:'+pct+'%"></div></div><div class="bk-val '+(pos?'pos':'neg')+'">'+(pos?'+':'')+b.points+'</div></div>';
    });
  } else {
    bl.innerHTML='<div class="bk-row"><div class="bk-label">Base score</div><div class="bk-bar"><div class="bk-bar-fill pos" style="width:100%"></div></div><div class="bk-val pos">+100</div></div>';
  }
  document.getElementById('resultsArea').style.display='block';
  // Show result 3D
  if(!window._resultSceneInited){window._resultSceneInited=true;initResultScene();}
}

/* ── Analyze ── */
var scanStats=['Parsing email headers…','Checking SPF / DKIM / DMARC…','Analyzing URL reputation…','Scanning payload signals…','Running neural classifier…','Scoring threat indicators…','Generating report…'];
var statIdx=0;
analyzeBtn.addEventListener('click',async function(){
  var text=emailInput.value.trim();
  if(text.length<50||!text.includes(' ')){showErr('Input does not look like a real email. Please paste full email content.');return;}
  clearErr();
  var overlay=document.getElementById('scanOverlay');
  overlay.classList.add('show');
  statIdx=0;
  var statEl=document.getElementById('scanStat');
  var statTimer=setInterval(function(){statEl.textContent=scanStats[statIdx%scanStats.length];statIdx++;},420);
  try{
    var res=await fetch('/api/email/analyze',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({emailContent:text})});
    var result=await res.json();
    clearInterval(statTimer);
    setTimeout(function(){
      overlay.classList.remove('show');
      if(result.riskLevel!=='Invalid'){showResults(result);toast('Analysis complete','Email scored: '+result.securityScore+'%','fa-shield-halved',result.securityScore>=70?'var(--ok)':result.securityScore>=40?'var(--warn)':'var(--red)');loadHistory();}
    },900);
  }catch(err){
    clearInterval(statTimer);overlay.classList.remove('show');
    showErr('Analysis failed. Please try again.');
    toast('Connection error','Check your network connection.','fa-triangle-exclamation','var(--red)');
  }
});

/* ── History ── */
async function loadHistory(){
  try{
    var res=await fetch('/api/email/history');
    if(res.status===401){document.getElementById('histGrid').innerHTML='<div style="grid-column:1/-1;padding:24px;text-align:center;font-family:\'DM Mono\',monospace;font-size:9px;letter-spacing:.12em;color:var(--c4)"><i class="fa-solid fa-lock" style="font-size:1.5rem;margin-bottom:8px;display:block;color:var(--warn)"></i>Login required to view history</div>';return;}
    var history=await res.json();
    var container=document.getElementById('histGrid');
    container.innerHTML='';
    if(!history.length){container.innerHTML='<div style="grid-column:1/-1;padding:24px;text-align:center;font-family:\'DM Mono\',monospace;font-size:9px;letter-spacing:.12em;color:var(--c4)"><i class="fa-solid fa-history" style="font-size:1.5rem;margin-bottom:8px;display:block;opacity:.3"></i>No history yet</div>';return;}
    history.forEach(function(h){
      var cls=h.riskLevel==='High'?'bad':h.riskLevel==='Medium'?'warn':'ok';
      var d=document.createElement('div');d.className='hist-card';
      d.innerHTML='<div class="hist-score '+cls+'">'+h.securityScore+'%</div><div class="hist-meta">Risk: '+h.riskLevel+'<br>Findings: '+(h.findingsCount||0)+'<br>'+new Date(h.createdAt).toLocaleString()+'</div>';
      container.appendChild(d);
    });
  }catch(e){console.error(e);}
}
