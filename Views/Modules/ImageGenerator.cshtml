    </div>

    <script>
        (function(){
        'use strict';

        /* ── Cursor ── */
        var CUR=document.getElementById('CUR'),CUR2=document.getElementById('CUR2'),mx=0,my=0,rx=0,ry=0;
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;CUR.style.left=mx+'px';CUR.style.top=my+'px';});
        (function L(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;CUR2.style.left=rx+'px';CUR2.style.top=ry+'px';requestAnimationFrame(L);})();
        document.querySelectorAll('a,button').forEach(function(el){
          el.addEventListener('mouseenter',function(){CUR2.style.width='50px';CUR2.style.height='50px';CUR2.style.borderColor='rgba(201,169,110,.9)';CUR2.style.background='rgba(201,169,110,.05)';});
          el.addEventListener('mouseleave',function(){CUR2.style.width='32px';CUR2.style.height='32px';CUR2.style.borderColor='rgba(201,169,110,.4)';CUR2.style.background='transparent';});
        });

        /* ── Status flicker ── */
        var statusEl=document.getElementById('statusTxt');
        var statusOptions=['READY','ACTIVE','STANDBY'];
        setInterval(function(){if(statusEl.textContent==='READY')statusEl.textContent=statusOptions[Math.floor(Math.random()*statusOptions.length)];},6000);

        /* ── Toast ── */
        var TW=document.getElementById('TW');
        function toast(h,p,ic,col){
          var el=document.createElement('div');el.className='toastx';
          el.innerHTML='<div class="t-ic" style="color:'+(col||'var(--g)')+'"><i class="fa-solid '+(ic||'fa-circle-info')+'"></i></div><div><div class="t-h">'+h+'</div><div class="t-p">'+p+'</div></div><button class="t-x"><i class="fa-solid fa-xmark"></i></button>';
          el.querySelector('.t-x').addEventListener('click',function(){el.remove();});
          TW.appendChild(el);setTimeout(function(){if(el.isConnected)el.remove();},5000);
        }

        /* ── Keyboard shortcut ── */
        document.getElementById('prompt').addEventListener('keydown',function(e){if((e.ctrlKey||e.metaKey)&&e.key==='Enter'){e.preventDefault();doGenerate();}});
        document.getElementById('genBtn').addEventListener('click',doGenerate);
        document.getElementById('regenBtn').addEventListener('click',doGenerate);

        /* ── Generate ── */
        var genSteps=['Encoding prompt tokens…','Building latent space…','Running diffusion steps…','Applying style transfer…','Decoding output image…','Upscaling & refining…','Finalizing render…'];

        async function doGenerate(){
          var prompt=document.getElementById('prompt').value.trim();
          if(!prompt){toast('Empty prompt','Please describe the image you want.','fa-triangle-exclamation','var(--warn)');return;}
          var btn=document.getElementById('genBtn');
          btn.disabled=true;
          document.getElementById('resultArea').classList.remove('show');
          statusEl.textContent='GENERATING';
          var progWrap=document.getElementById('progWrap'),progFill=document.getElementById('progFill'),progStatus=document.getElementById('progStatus');
          progWrap.classList.add('show');progStatus.classList.add('show');progFill.style.width='0%';
          var stepIdx=0;
          var stepTimer=setInterval(function(){progStatus.textContent=genSteps[stepIdx%genSteps.length];stepIdx++;progFill.style.width=Math.min(90,(stepIdx/genSteps.length)*90)+'%';},450);
          try{
                           var model = document.getElementById("modelSelect").value;

        var res = await fetch('/api/image/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                prompt: prompt,
                model: model
            })
        });

        if (!res.ok) throw new Error("Generation failed");

        var data = await res.json();
            clearInterval(stepTimer);progFill.style.width='100%';
            var imgUrl=data.imageUrl||'https://placehold.co/900x600/04040a/c9a96e?text=Generated+Image';
            showResult(imgUrl);
          }catch(err){
            clearInterval(stepTimer);progFill.style.width='100%';
            var demo='https://placehold.co/900x600/04040a/c9a96e?text='+encodeURIComponent(prompt.substring(0,30));
            showResult(demo);
            toast('Demo mode','API unavailable — using placeholder.','fa-image','var(--warn)');
          }
          function showResult(url){
            setTimeout(function(){
              progWrap.classList.remove('show');progStatus.classList.remove('show');
              document.getElementById('generatedImage').src=url;
              document.getElementById('downloadBtn').href=url;
              document.getElementById('resultArea').classList.add('show');
              statusEl.textContent='COMPLETE';
              setTimeout(function(){statusEl.textContent='READY';},4000);
              toast('Image generated','Diffusion render complete.','fa-circle-check','var(--ok)');
              btn.disabled=false;
            },500);
          }
        }

        /* ═══════════════════════════
           THREE.JS
        ═══════════════════════════ */
        function lerp(a,b,t){return a+(b-a)*t;}
        function eL(c,op){return new THREE.LineBasicMaterial({color:c,transparent:true,opacity:op});}
        function mPP(c,op,r){return new THREE.MeshPhysicalMaterial({color:c,metalness:.95,roughness:r||.04,transparent:true,opacity:op||.08,side:THREE.DoubleSide,transmission:.88,thickness:.6,ior:1.5});}
        function mBB(c,op){return new THREE.MeshBasicMaterial({color:c,transparent:true,opacity:op});}
        function mkR(canvas){var r=new THREE.WebGLRenderer({canvas:canvas,antialias:true,alpha:true,powerPreference:'high-performance'});r.setPixelRatio(Math.min(window.devicePixelRatio,1.8));r.toneMapping=THREE.ACESFilmicToneMapping;r.toneMappingExposure=1.1;return r;}

        /* ── GLOBAL BG ── */
        (function(){
          var canvas=document.getElementById('BG');
          var W=function(){return window.innerWidth;},H=function(){return window.innerHeight;};
          var renderer=mkR(canvas);renderer.setSize(W(),H());
          canvas.style.cssText='position:fixed;inset:0;z-index:0;pointer-events:none;width:100%;height:100%';
          var scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x04040a,.02);
          var camera=new THREE.PerspectiveCamera(56,W()/H(),.1,500);camera.position.set(0,0,22);
          scene.add(new THREE.AmbientLight(0x04040e,2.5));
          var kL=new THREE.SpotLight(0xc9a96e,20,100,Math.PI/6,.35,1.2);kL.position.set(18,22,16);scene.add(kL);
          var fL=new THREE.SpotLight(0x8b5cf6,10,80,Math.PI/5,.4,1.5);fL.position.set(-20,10,12);scene.add(fL);
          var p1=new THREE.PointLight(0xc9a96e,6,42);scene.add(p1);var p2=new THREE.PointLight(0x8b5cf6,4,30);scene.add(p2);
          var objs=[];
          function addCube(x,y,z,s,mat){var g=new THREE.BoxGeometry(1,1,1,2,2,2),m=new THREE.Mesh(g,mat);m.scale.setScalar(s);m.position.set(x,y,z);m.rotation.set(Math.random()*6.28,Math.random()*6.28,Math.random()*6.28);m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eL(0xc9a96e,.15)));scene.add(m);objs.push({m:m,ox:x,oy:y,oz:z,fp:Math.random()*6.28,fs:.2+Math.random()*.25,rs:{x:(Math.random()-.5)*.005,y:(Math.random()-.5)*.005,z:(Math.random()-.5)*.003}});}
          for(var i=0;i<28;i++){addCube((Math.random()-.5)*40,(Math.random()-.5)*22,-8-Math.random()*16,.5+Math.random()*2.5,i%3===0?new THREE.MeshBasicMaterial({color:0xc9a96e,wireframe:true,transparent:true,opacity:.06}):mPP(0xc9a96e,.04));}
          var tori=[];
          [{r:3,tb:.006,c:0xc9a96e,op:.2,rx:1.05,rz:.2,rs:.004},{r:5,tb:.004,c:0x8b5cf6,op:.14,rx:.78,rz:0,rs:.003},{r:7,tb:.003,c:0x4ecdc4,op:.08,rx:.52,rz:.52,rs:.002}].forEach(function(d){var g=new THREE.TorusGeometry(d.r,d.tb,2,90),m=new THREE.Mesh(g,mBB(d.c,d.op));m.rotation.set(d.rx,0,d.rz);scene.add(m);tori.push({m:m,rs:d.rs,fp:Math.random()*6.28,fs:.2+Math.random()*.2});});
          function mkP(n,spr,zMin,zSpr,col,sz,op){var g=new THREE.BufferGeometry(),pos=new Float32Array(n*3);for(var ii=0;ii<n;ii++){pos[ii*3]=(Math.random()-.5)*spr;pos[ii*3+1]=(Math.random()-.5)*spr*.5;pos[ii*3+2]=zMin-Math.random()*zSpr;}g.setAttribute('position',new THREE.BufferAttribute(pos,3));var pts=new THREE.Points(g,new THREE.PointsMaterial({color:col,size:sz,transparent:true,opacity:op,sizeAttenuation:true}));scene.add(pts);return pts;}
          var pA=mkP(900,70,4,28,0xc9a96e,.032,.24),pB=mkP(160,28,2,12,0x8b5cf6,.055,.32);
          var tmx=0,tmy=0,cmx=0,cmy=0;
          document.addEventListener('mousemove',function(e){tmx=(e.clientX/W()-.5)*2;tmy=-(e.clientY/H()-.5)*2;});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
          var clock=new THREE.Clock();
          (function tick(){requestAnimationFrame(tick);var t=clock.getElapsedTime();cmx+=(tmx-cmx)*.016;cmy+=(tmy-cmy)*.016;camera.position.x=lerp(camera.position.x,cmx*3,.055);camera.position.y=lerp(camera.position.y,cmy*2,.055);p1.position.set(9+Math.sin(t*.38)*5,9+Math.cos(t*.28)*4,8);p2.position.set(-10+Math.cos(t*.32)*3,-7+Math.sin(t*.26)*2.5,9);objs.forEach(function(o){o.m.rotation.x+=o.rs.x;o.m.rotation.y+=o.rs.y;o.m.rotation.z+=o.rs.z;o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.4;});tori.forEach(function(o){o.m.rotation.z+=o.rs;o.m.rotation.y+=o.rs*.6;});pA.rotation.y=t*.007;pB.rotation.y=-t*.011;renderer.render(scene,camera);})();
        })();

        /* ── HERO 3D ── */
        (function(){
          var canvas=document.getElementById('HERO3D');
          var wrap=canvas.parentElement;
          var W=function(){return wrap.offsetWidth;},H=function(){return wrap.offsetHeight;};
          var renderer=mkR(canvas);renderer.setSize(W(),H());
          var scene=new THREE.Scene();var camera=new THREE.PerspectiveCamera(52,W()/H(),.1,100);camera.position.set(0,0,10);
          scene.add(new THREE.AmbientLight(0x04040e,2));
          var kL=new THREE.SpotLight(0xc9a96e,24,50,Math.PI/5,.3,1.2);kL.position.set(10,14,12);scene.add(kL);
          var fL=new THREE.SpotLight(0x8b5cf6,16,38,Math.PI/4,.35,1.5);fL.position.set(-9,6,9);scene.add(fL);
          var bL=new THREE.SpotLight(0x4ecdc4,10,28,Math.PI/3,.5,1.8);bL.position.set(-4,-9,7);scene.add(bL);
          var p1=new THREE.PointLight(0xc9a96e,8,22);scene.add(p1);var p2=new THREE.PointLight(0x8b5cf6,5,17);scene.add(p2);
          var cubes=[];
          [[5,.06,.04,0xc9a96e],[3.2,.08,.05,0x8b5cf6],[1.9,.1,.04,0x4ecdc4],[1,.12,.03,0xc9a96e],[.5,.15,.04,0xd4b87e]].forEach(function(d,i){var g=new THREE.BoxGeometry(d[0],d[0],d[0],3,3,3);var m=new THREE.Mesh(g,mPP(d[3],d[1],d[2]));m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eL(d[3],i===0?.44:.62)));scene.add(m);cubes.push({m:m,rx:(.003+i*.0022)*(i%2===0?1:-1),ry:.0038+i*.0025,rz:.0014+i*.001});});
          var orbs=[];
          for(var oi=0;oi<16;oi++){var sz=.18+Math.random()*.6;var g2=new THREE.BoxGeometry(sz,sz,sz,2,2,2);var col=oi%3===0?0xc9a96e:oi%3===1?0x8b5cf6:0x4ecdc4;var om=new THREE.Mesh(g2,mPP(col,.1,.05));om.add(new THREE.LineSegments(new THREE.EdgesGeometry(g2),eL(col,.58)));scene.add(om);orbs.push({m:om,r:2.5+Math.random()*4.2,sp:.22+Math.random()*.54,ph:oi*.393,ti:.32+Math.random()*.5,type:'orb'});}
          [{r:3.5,tb:.007,c:0xc9a96e,op:.26,rx:1.05,rz:0,rs:.006},{r:5,tb:.005,c:0x8b5cf6,op:.18,rx:.78,rz:.78,rs:.005},{r:6.5,tb:.003,c:0x4ecdc4,op:.12,rx:.52,rz:.52,rs:.003},{r:8,tb:.002,c:0xd4b87e,op:.07,rx:.3,rz:1.05,rs:.0018}].forEach(function(d){var g=new THREE.TorusGeometry(d.r,d.tb,2,100),m=new THREE.Mesh(g,mBB(d.c,d.op));m.rotation.x=d.rx;m.rotation.z=d.rz;scene.add(m);orbs.push({m:m,type:'ring',rs:d.rs});});
          [[3,.055,0xc9a96e],[4.5,.034,0x8b5cf6],[6,.02,0x4ecdc4]].forEach(function(d){scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.IcosahedronGeometry(d[0],1)),eL(d[2],d[1])));});
          var pings=[];for(var pi=0;pi<20;pi++){var phi=Math.acos(2*Math.random()-1),theta=Math.random()*Math.PI*2,rr=3.2;var pd=new THREE.Mesh(new THREE.SphereGeometry(.06,5,5),new THREE.MeshBasicMaterial({color:pi%3===0?0xc9a96e:pi%3===1?0x8b5cf6:0x4ecdc4,transparent:true,opacity:.85}));pd.position.set(rr*Math.sin(phi)*Math.cos(theta),rr*Math.cos(phi),rr*Math.sin(phi)*Math.sin(theta));scene.add(pd);pings.push({m:pd,fp:Math.random()*6.28,fs:.3+Math.random()*.7});}
          function mkSP(n,mn,mx,col,sz,op){var g=new THREE.BufferGeometry(),pos=new Float32Array(n*3);for(var ii=0;ii<n;ii++){var r=mn+Math.random()*(mx-mn),th=Math.random()*6.28,ph=Math.acos(2*Math.random()-1);pos[ii*3]=r*Math.sin(ph)*Math.cos(th);pos[ii*3+1]=r*Math.sin(ph)*Math.sin(th);pos[ii*3+2]=r*Math.cos(ph);}g.setAttribute('position',new THREE.BufferAttribute(pos,3));var pts=new THREE.Points(g,new THREE.PointsMaterial({color:col,size:sz,transparent:true,opacity:op,sizeAttenuation:true}));scene.add(pts);return pts;}
          var sp1=mkSP(600,3.5,9,0xc9a96e,.04,.5),sp2=mkSP(200,5,7,0x8b5cf6,.05,.36);
          var hmx=0,hmy=0,thmx=0,thmy=0;
          document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();thmx=(e.clientX-rc.left-rc.width/2)/(rc.width/2);thmy=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
