          var coreObjs=[];
          [[4.2,.06,.04,0xc9a96e],[2.8,.08,.05,0x8b5cf6],[1.7,.1,.04,0x4ecdc4],[.9,.13,.03,0xd4b87e],[.45,.16,.04,0xc9a96e]].forEach(function(d,i){var g=new THREE.BoxGeometry(d[0],d[0],d[0],3,3,3);var m=new THREE.Mesh(g,mPP(d[3],d[1],d[2]));m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eL(d[3],i===0?.42:.64)));scene.add(m);coreObjs.push({m:m,rx:(.003+i*.0025)*(i%2===0?1:-1),ry:.004+i*.003,rz:.002+i*.0015,type:'core'});});
          for(var oi=0;oi<20;oi++){var sz=.17+Math.random()*.58;var g2=new THREE.BoxGeometry(sz,sz,sz,2,2,2);var col=oi%4===0?0xc9a96e:oi%4===1?0x8b5cf6:oi%4===2?0x4ecdc4:0xd4b87e;var om=new THREE.Mesh(g2,mPP(col,.1,.05));om.add(new THREE.LineSegments(new THREE.EdgesGeometry(g2),eL(col,.58)));scene.add(om);coreObjs.push({m:om,r:2.6+Math.random()*4.8,sp:.2+Math.random()*.54,ph:oi*.314,ti:.3+Math.random()*.6,type:'orb'});}
          [{r:3,tb:.007,c:0xc9a96e,op:.24,rx:1.05,rz:0,rs:.006},{r:4.2,tb:.005,c:0x8b5cf6,op:.18,rx:.78,rz:.78,rs:.005},{r:5.5,tb:.004,c:0x4ecdc4,op:.12,rx:.52,rz:.52,rs:.004},{r:7,tb:.003,c:0xd4b87e,op:.08,rx:.3,rz:1.05,rs:.002},{r:4.5,tb:.006,c:0x8b5cf6,op:.15,rx:.4,rz:.6,rs:.005},{r:6,tb:.003,c:0x4ecdc4,op:.1,rx:.7,rz:.78,rs:.003}].forEach(function(d){var g=new THREE.TorusGeometry(d.r,d.tb,2,100),m=new THREE.Mesh(g,mBB(d.c,d.op));m.rotation.x=d.rx;m.rotation.z=d.rz;scene.add(m);coreObjs.push({m:m,rs:d.rs,type:'ring'});});
          [[2.2,.06,0xc9a96e],[3.4,.04,0x8b5cf6],[4.8,.024,0x4ecdc4],[6.2,.015,0xd4b87e]].forEach(function(d){scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.IcosahedronGeometry(d[0],1)),eL(d[2],d[1])));});
          var tpings=[];for(var pi=0;pi<18;pi++){var phi=Math.acos(2*Math.random()-1),theta=Math.random()*Math.PI*2,rr=2.4;var pd=new THREE.Mesh(new THREE.SphereGeometry(.065,5,5),new THREE.MeshBasicMaterial({color:pi%3===0?0x8b5cf6:pi%3===1?0xc9a96e:0x4ecdc4,transparent:true,opacity:.88}));pd.position.set(rr*Math.sin(phi)*Math.cos(theta),rr*Math.cos(phi),rr*Math.sin(phi)*Math.sin(theta));scene.add(pd);tpings.push({m:pd,fp:Math.random()*6.28,fs:.3+Math.random()*.7});}
          var spg=new THREE.BufferGeometry(),spPos=new Float32Array(700*3);for(var si=0;si<700;si++){var sr=2+Math.random()*7,st=Math.random()*6.28,sphi=Math.acos(2*Math.random()-1);spPos[si*3]=sr*Math.sin(sphi)*Math.cos(st);spPos[si*3+1]=sr*Math.sin(sphi)*Math.sin(st);spPos[si*3+2]=sr*Math.cos(sphi);}spg.setAttribute('position',new THREE.BufferAttribute(spPos,3));var spPts=new THREE.Points(spg,new THREE.PointsMaterial({color:0xc9a96e,size:.036,transparent:true,opacity:.42,sizeAttenuation:true}));scene.add(spPts);
          var hmx3=0,hmy3=0,thmx3=0,thmy3=0;document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();thmx3=(e.clientX-rc.left-rc.width/2)/(rc.width/2);thmy3=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
          var clk=new THREE.Clock();var ri=0;
          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();hmx3+=(thmx3-hmx3)*.055;hmy3+=(thmy3-hmy3)*.055;coreObjs.forEach(function(o){if(o.type==='core'){o.m.rotation.x+=o.rx;o.m.rotation.y+=o.ry;o.m.rotation.z+=o.rz;}else if(o.type==='orb'){var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.42,Math.sin(a)*o.r*.68);o.m.rotation.x+=.007;o.m.rotation.y+=.01;}else if(o.type==='ring'){ri++;o.m.rotation.z+=o.rs*(ri%2===0?1:-1);o.m.rotation.y+=o.rs*.6;o.m.rotation.x+=o.rs*.22;}});ri=0;tpings.forEach(function(p){var s=.6+Math.sin(t*p.fs+p.fp)*.42;p.m.scale.setScalar(s);p.m.material.opacity=.45+Math.sin(t*p.fs+p.fp)*.44;});spPts.rotation.y=t*.014;spPts.rotation.x=t*.007;camera.position.x=hmx3*2;camera.position.y=hmy3*1.6;camera.lookAt(hmx3*.25,hmy3*.2,0);p1.position.set(4+Math.sin(t*.45)*2.5,4+Math.cos(t*.35)*2,6);p2.position.set(-4+Math.cos(t*.38)*2,-3+Math.sin(t*.28)*2,5);kL.intensity=22+Math.sin(t*.28)*7;fL.intensity=18+Math.sin(t*.22+1)*5;renderer.render(scene,camera);})();
