            [[3,.006,0xc9a96e,.26,1.05,0,.005],[3.8,.004,accent1,.16,.78,.78,.004],[4.5,.003,accent2,.11,.52,.52,.003]].forEach(function(d){var g=new THREE.TorusGeometry(d[0],d[1],2,80),m=new THREE.Mesh(g,mBB(d[2],d[3]));m.rotation.x=d[4];m.rotation.z=d[5];scene.add(m);objs.push({m:m,rs:d[6],type:'ring'});});
