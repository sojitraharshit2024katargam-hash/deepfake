          var pP=new Float32Array(800*3);for(var i=0;i<800;i++){var r=5+Math.random()*7,th=Math.random()*6.28,ph=Math.acos(2*Math.random()-1);pP[i*3]=r*Math.sin(ph)*Math.cos(th);pP[i*3+1]=r*Math.sin(ph)*Math.sin(th);pP[i*3+2]=r*Math.cos(ph);}
          var pG=new THREE.BufferGeometry();pG.setAttribute('position',new THREE.BufferAttribute(pP,3));
          scene.add(new THREE.Points(pG,new THREE.PointsMaterial({color:0xc9a96e,size:.038,transparent:true,opacity:.28,sizeAttenuation:true})));

          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
          var hmx=0,hmy=0,tmx=0,tmy=0;
          canvas.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();tmx=(e.clientX-rc.left-rc.width/2)/(rc.width/2);tmy=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          var clk=new THREE.Clock();
          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            hmx+=(tmx-hmx)*.06;hmy+=(tmy-hmy)*.06;
            /* Wave through grid nodes */
            gridNodes.forEach(function(n){
              var wave=Math.sin(t*.9+n.ph)*.22;
              n.m.position.y=n.oy+wave;n.m.scale.setScalar(.7+Math.abs(wave)*.7);
              n.m.material.opacity=.3+Math.abs(wave)*.7;
            });
            helixG.rotation.y=t*.2+hmx*.5;helixG.rotation.x=Math.sin(t*.07)*.08+hmy*.3;
            gridGroup.rotation.y=t*.04+hmx*.15;gridGroup.rotation.x=Math.sin(t*.05)*.04+hmy*.1;
            kL.position.set(8+Math.sin(t*.38)*2.5,8+Math.cos(t*.3)*2,8);
            fL.position.set(-7+Math.cos(t*.32)*2,-4+Math.sin(t*.26)*2,7);
            renderer.render(scene,camera);
          })();
        })();

        })();
    </script>
</body>
</html>