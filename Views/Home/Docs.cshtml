                        <tr><td>403</td><td><code style="color:var(--red)">PLAN_REQUIRED</code></td><td>Feature not available on current plan</td></tr>
                        <tr><td>413</td><td><code style="color:var(--warn)">PAYLOAD_TOO_LARGE</code></td><td>File exceeds plan's max payload size</td></tr>
                        <tr><td>429</td><td><code style="color:var(--warn)">RATE_LIMIT_EXCEEDED</code></td><td>Too many requests — check Retry-After</td></tr>
                        <tr><td>500</td><td><code style="color:var(--red)">INTERNAL_ERROR</code></td><td>Transient server error — retry with backoff</td></tr>
