                <div class="callout warn reveal" style="transition-delay:.1s"><i class="fa-solid fa-triangle-exclamation"></i><div>Validate the <code style="color:var(--g)">X-Nexus-Signature</code> header on every webhook to ensure it originated from Deepfake Nexus. Reject requests with invalid signatures.</div></div>

                <div class="code-wrap reveal" style="transition-delay:.12s">
                    <div class="code-header"><span class="code-lang"><i class="fa-brands fa-node-js"></i>Node.js · Webhook Validation</span><button class="copy-btn" onclick="copyCode(this)"><i class="fa-regular fa-copy"></i> Copy</button></div>
                    <div class="code-body">
                        <span class="kw">const</span> crypto = <span class="fn">require</span>(<span class="st">'crypto'</span>);

                        <span class="fn">app</span>.<span class="fn">post</span>(<span class="st">'/webhook'</span>, (req, res) => {
                        <span class="kw">const</span> sig = req.headers[<span class="st">'x-nexus-signature'</span>];
                        <span class="kw">const</span> expected = crypto
                        .<span class="fn">createHmac</span>(<span class="st">'sha256'</span>, process.env.WEBHOOK_SECRET)
                        .<span class="fn">update</span>(req.rawBody)
                        .<span class="fn">digest</span>(<span class="st">'hex'</span>);

                        <span class="kw">if</span> (sig !== <span class="st">`sha256=</span><span class="kw">${</span>expected<span class="kw">}</span><span class="st">`</span>) {
                        <span class="kw">return</span> res.<span class="fn">status</span>(<span class="num">401</span>).<span class="fn">send</span>(<span class="st">'Unauthorized'</span>);
                        }

                        <span class="kw">const</span> event = req.body;
                        <span class="cm">// event.type: 'analysis.complete' | 'threat.critical'</span>
                        <span class="cm">// event.data: full analysis result</span>
                        res.<span class="fn">status</span>(<span class="num">200</span>).<span class="fn">send</span>(<span class="st">'OK'</span>);
                        });
                    </div>
                </div>

