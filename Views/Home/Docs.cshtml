    <!-- ══════════════════════════
         SCRIPTS
    ══════════════════════════ -->
    <script>
        (function(){
        'use strict';

        /* ── Cursor ── */
        var CUR=document.getElementById('CUR'),CUR2=document.getElementById('CUR2'),mx=0,my=0,rx=0,ry=0;
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;CUR.style.left=mx+'px';CUR.style.top=my+'px';});
        (function L(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;CUR2.style.left=rx+'px';CUR2.style.top=ry+'px';requestAnimationFrame(L);})();
        document.querySelectorAll('a,button,.qs-card,.step,.endpoint-card,.sb-link').forEach(function(el){el.addEventListener('mouseenter',function(){CUR2.style.width='44px';CUR2.style.height='44px';CUR2.style.borderColor='rgba(201,169,110,.9)';});el.addEventListener('mouseleave',function(){CUR2.style.width='28px';CUR2.style.height='28px';CUR2.style.borderColor='rgba(201,169,110,.4)';});});

        /* ── Clock ── */
        function tick(){var d=new Date();document.getElementById('h_time').textContent=d.toUTCString().split(' ')[4]+' UTC';}
        tick();setInterval(tick,1000);

        /* ── Scroll reveal ── */
        var rio=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('vis');rio.unobserve(x.target);}});},{threshold:.08,rootMargin:'0px 0px -30px 0px'});
        document.querySelectorAll('.reveal').forEach(function(el){rio.observe(el);});

        /* ── Sidebar active ── */
        var sections=['quickstart','authentication','rate-limits','api-reference','email-api','media-api','webhooks','errors','changelog'];
        var sio=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){var id=x.target.id;document.querySelectorAll('.sb-link').forEach(function(l){l.classList.remove('active');});var a=document.querySelector('.sb-link[href="#'+id+'"]');if(a)a.classList.add('active');updateToc(id);}});},{threshold:.3,rootMargin:'-120px 0px -40% 0px'});
        sections.forEach(function(id){var el=document.getElementById(id);if(el)sio.observe(el);});

        /* ── TOC dots ── */
        var TOC=document.getElementById('TOC_DOTS');
        var tocData=[{id:'quickstart',label:'Quick Start'},{id:'authentication',label:'Auth'},{id:'rate-limits',label:'Limits'},{id:'api-reference',label:'API Ref'},{id:'email-api',label:'Email'},{id:'media-api',label:'Media'},{id:'webhooks',label:'Webhooks'},{id:'errors',label:'Errors'},{id:'changelog',label:'Changelog'}];
        tocData.forEach(function(d,i){var dot=document.createElement('div');dot.className='toc-dot';dot.dataset.id=d.id;dot.dataset.label=d.label;dot.title=d.label;dot.addEventListener('click',function(){document.getElementById(d.id).scrollIntoView({behavior:'smooth'});});TOC.appendChild(dot);if(i<tocData.length-1){var line=document.createElement('div');line.className='toc-line';TOC.appendChild(line);}});
        function updateToc(id){document.querySelectorAll('.toc-dot').forEach(function(d){d.classList.toggle('on',d.dataset.id===id);});}

        /* ── SDK tabs ── */
        window.switchTab=function(group,lang){document.querySelectorAll('.sdk-tab').forEach(function(t){if(t.closest('#'+group+'_TABS'))t.classList.toggle('on',t.textContent.toLowerCase().includes(lang));});document.querySelectorAll('.sdk-content[data-tab="'+group+'"]').forEach(function(c){c.classList.toggle('on',c.dataset.lang===lang);});};

        /* ── Filter tag ── */
        window.filterTag=function(el,tag){document.querySelectorAll('.stag').forEach(function(s){s.classList.remove('on');});el.classList.add('on');};

        /* ── Copy ── */
        window.copyCode=function(btn){var code=btn.closest('.code-wrap').querySelector('.code-body');var text=code.innerText;navigator.clipboard.writeText(text).then(function(){btn.innerHTML='<i class="fa-solid fa-check"></i> Copied';setTimeout(function(){btn.innerHTML='<i class="fa-regular fa-copy"></i> Copy';},2000);});};

        /* ── Toast ── */
        var TW=document.getElementById('TW');
        function toast(h,p,ic,col){var el=document.createElement('div');el.className='toastx';el.innerHTML='<div class="t-ic2" style="color:'+(col||'var(--g)')+'"><i class="fa-solid '+(ic||'fa-circle-info')+'"></i></div><div><div class="t-h">'+h+'</div><div class="t-p">'+p+'</div></div><button class="t-x2"><i class="fa-solid fa-xmark"></i></button>';el.querySelector('.t-x2').addEventListener('click',function(){el.remove();});TW.appendChild(el);setTimeout(function(){if(el.isConnected)el.remove();},5000);}
        setTimeout(function(){toast('API docs loaded','All 14 endpoints documented.','fa-book');},1400);

        /* ════════════════════════════════════
           THREE.JS — Completely new 3D systems
        ════════════════════════════════════ */
        function lerp(a,b,t){return a+(b-a)*t;}
        function mBB(c,op){return new THREE.MeshBasicMaterial({color:c,transparent:true,opacity:op});}
        function eL(c,op){return new THREE.LineBasicMaterial({color:c,transparent:true,opacity:op});}
        function mkR(canvas){var r=new THREE.WebGLRenderer({canvas:canvas,antialias:true,alpha:true,powerPreference:'high-performance'});r.setPixelRatio(Math.min(window.devicePixelRatio,1.8));r.toneMapping=THREE.ACESFilmicToneMapping;r.toneMappingExposure=1.15;return r;}

        /* ═══════════════════════════════════════════
           BG: VOLUMETRIC DIFFUSION FIELD
           Completely new — flowing particle field
           with curl noise simulation
        ═══════════════════════════════════════════ */
        (function(){
          var canvas=document.getElementById('BG');
          var W=function(){return window.innerWidth;},H=function(){return window.innerHeight;};
          var renderer=mkR(canvas);renderer.setSize(W(),H());
          canvas.style.cssText='position:fixed;inset:0;z-index:0;pointer-events:none;width:100%;height:100%';
          var scene=new THREE.Scene();
          var camera=new THREE.PerspectiveCamera(60,W()/H(),.1,600);camera.position.set(0,0,30);
          scene.add(new THREE.AmbientLight(0x04040e,3));
          var kL=new THREE.PointLight(0xc9a96e,8,55);scene.add(kL);
          var fL=new THREE.PointLight(0x8b5cf6,6,40);scene.add(fL);
          var tL=new THREE.PointLight(0x4ecdc4,4,35);scene.add(tL);

          /* DIFFUSION FIELD — 3000 flowing particles */
          var N=3000;
          var positions=new Float32Array(N*3);
          var velocities=new Float32Array(N*3);
          var phases=new Float32Array(N);
          for(var i=0;i<N;i++){
            positions[i*3]=(Math.random()-.5)*80;
            positions[i*3+1]=(Math.random()-.5)*45;
            positions[i*3+2]=-5-Math.random()*20;
            velocities[i*3]=(Math.random()-.5)*.006;
            velocities[i*3+1]=(Math.random()-.5)*.004;
            velocities[i*3+2]=0;
            phases[i]=Math.random()*6.28;
          }
          var pGeo=new THREE.BufferGeometry();
          pGeo.setAttribute('position',new THREE.BufferAttribute(positions,3));
          var pMat=new THREE.PointsMaterial({color:0xc9a96e,size:.065,transparent:true,opacity:.4,sizeAttenuation:true,vertexColors:false});
          var particles=new THREE.Points(pGeo,pMat);scene.add(particles);

          /* Secondary field — purple */
          var N2=1200;
          var pos2=new Float32Array(N2*3);
          for(var i=0;i<N2;i++){pos2[i*3]=(Math.random()-.5)*60;pos2[i*3+1]=(Math.random()-.5)*35;pos2[i*3+2]=-8-Math.random()*16;}
          var pGeo2=new THREE.BufferGeometry();pGeo2.setAttribute('position',new THREE.BufferAttribute(pos2,3));
          var p2=new THREE.Points(pGeo2,new THREE.PointsMaterial({color:0x8b5cf6,size:.05,transparent:true,opacity:.22,sizeAttenuation:true}));scene.add(p2);

          /* Tertiary — teal */
          var N3=600;
          var pos3=new Float32Array(N3*3);
          for(var i=0;i<N3;i++){pos3[i*3]=(Math.random()-.5)*50;pos3[i*3+1]=(Math.random()-.5)*28;pos3[i*3+2]=-12-Math.random()*12;}
          var pGeo3=new THREE.BufferGeometry();pGeo3.setAttribute('position',new THREE.BufferAttribute(pos3,3));
          var p3=new THREE.Points(pGeo3,new THREE.PointsMaterial({color:0x4ecdc4,size:.04,transparent:true,opacity:.18,sizeAttenuation:true}));scene.add(p3);

          /* Large ambient geometry — faint */
          [[16,.025,.035,0xc9a96e],[11,.03,.04,0x8b5cf6],[7,.04,.03,0x4ecdc4]].forEach(function(d){
            var g=new THREE.TorusGeometry(d[0],d[1],2,120);
            var m=new THREE.Mesh(g,mBB(d[3],d[2]));
            m.rotation.x=Math.random()*3.14;m.rotation.z=Math.random()*3.14;
            scene.add(m);
          });

          var cmx=0,cmy=0,tmx=0,tmy=0,scrollY=0;
          document.addEventListener('mousemove',function(e){tmx=(e.clientX/W()-.5)*2;tmy=-(e.clientY/H()-.5)*2;});
          window.addEventListener('scroll',function(){scrollY=window.scrollY;},{passive:true});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});

          /* Simplex-like curl noise approximation */
          function sn(x,y,t){return Math.sin(x*1.3+t*.38)*Math.cos(y*.9+t*.24)*Math.sin(x*.7-y*.8+t*.18);}
          function curl(x,y,z,t){var e=.4;var dx=(sn(x,y+e,t)-sn(x,y-e,t))/(2*e);var dy=-(sn(x+e,y,t)-sn(x-e,y,t))/(2*e);return{x:dx,y:dy};}

          var clk=new THREE.Clock();
          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            cmx+=(tmx-cmx)*.014;cmy+=(tmy-cmy)*.014;

            /* Update diffusion field */
            var pos=pGeo.attributes.position.array;
            for(var i=0;i<N;i++){
              var x=pos[i*3],y=pos[i*3+1],z=pos[i*3+2];
              var c=curl(x*.04,y*.04,z*.02,t);
              pos[i*3]+=velocities[i*3]+c.x*.12+cmx*.008;
              pos[i*3+1]+=velocities[i*3+1]+c.y*.08+cmy*.006;
              /* wrap */
              if(pos[i*3]>40)pos[i*3]=-40;if(pos[i*3]<-40)pos[i*3]=40;
              if(pos[i*3+1]>23)pos[i*3+1]=-23;if(pos[i*3+1]<-23)pos[i*3+1]=23;
            }
            pGeo.attributes.position.needsUpdate=true;

            var sP=Math.min(1,scrollY/Math.max(1,document.body.scrollHeight-H()));
            camera.position.x=cmx*5;camera.position.y=cmy*3+sP*-8;camera.position.z=lerp(camera.position.z,30-sP*14,.055);
            kL.position.set(18+Math.sin(t*.32)*6,14+Math.cos(t*.24)*4,12);
            fL.position.set(-16+Math.cos(t*.28)*5,-10+Math.sin(t*.21)*3,10);
            tL.position.set(Math.sin(t*.38)*8,-12+Math.cos(t*.34)*4,8);
            p2.rotation.y=t*.009;p2.rotation.x=t*.004;
            p3.rotation.y=-t*.011;p3.rotation.x=t*.006;
            renderer.render(scene,camera);
          })();
        })();

        /* ═══════════════════════════════════════
           HERO: DNA DOUBLE HELIX + NEURAL SPHERE
        ═══════════════════════════════════════ */
        (function(){
          var canvas=document.getElementById('HERO_CANVAS');
          var wrap=canvas.parentElement;
          var W=function(){return wrap.offsetWidth;},H=function(){return wrap.offsetHeight;};
          var renderer=mkR(canvas);renderer.setSize(W(),H());
          var scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x04040a,.022);
          var camera=new THREE.PerspectiveCamera(55,W()/H(),.1,100);camera.position.set(0,0,14);
          scene.add(new THREE.AmbientLight(0x04040a,2));
          var kL=new THREE.SpotLight(0xc9a96e,28,50,Math.PI/4,.28,1.2);kL.position.set(14,18,16);scene.add(kL);
          var fL=new THREE.SpotLight(0x8b5cf6,20,38,Math.PI/3,.32,1.5);fL.position.set(-12,6,12);scene.add(fL);
          var tL=new THREE.SpotLight(0x4ecdc4,14,30,Math.PI/3,.38,1.8);tL.position.set(-4,-12,10);scene.add(tL);
          var p1=new THREE.PointLight(0xc9a96e,10,24);scene.add(p1);
          var p2=new THREE.PointLight(0x8b5cf6,7,18);scene.add(p2);

          /* === DNA DOUBLE HELIX === */
          var helixGroup=new THREE.Group();scene.add(helixGroup);
          var helixN=80,helixR=3,helixH=18,turns=5;
          var strand1Pts=[],strand2Pts=[];
          for(var i=0;i<helixN;i++){
            var t2=i/helixN;var angle=t2*turns*Math.PI*2;var y=t2*helixH-helixH/2;
            strand1Pts.push(new THREE.Vector3(Math.cos(angle)*helixR,y,Math.sin(angle)*helixR));
            strand2Pts.push(new THREE.Vector3(Math.cos(angle+Math.PI)*helixR,y,Math.sin(angle+Math.PI)*helixR));
          }
          var s1Geo=new THREE.BufferGeometry().setFromPoints(strand1Pts);
          var s2Geo=new THREE.BufferGeometry().setFromPoints(strand2Pts);
          helixGroup.add(new THREE.Line(s1Geo,new THREE.LineBasicMaterial({color:0xc9a96e,transparent:true,opacity:.7})));
          helixGroup.add(new THREE.Line(s2Geo,new THREE.LineBasicMaterial({color:0x8b5cf6,transparent:true,opacity:.7})));

          /* Rungs between strands */
          var rungStep=4;
          for(var i=0;i<helixN;i+=rungStep){
            var t2=i/helixN;var angle=t2*turns*Math.PI*2;var y=t2*helixH-helixH/2;
            var a1=new THREE.Vector3(Math.cos(angle)*helixR,y,Math.sin(angle)*helixR);
            var a2=new THREE.Vector3(Math.cos(angle+Math.PI)*helixR,y,Math.sin(angle+Math.PI)*helixR);
            var rGeo=new THREE.BufferGeometry().setFromPoints([a1,a2]);
            var rCol=i%8===0?0xc9a96e:i%8===rungStep?0x4ecdc4:i%8===rungStep*2?0x8b5cf6:0xd4b87e;
            helixGroup.add(new THREE.Line(rGeo,new THREE.LineBasicMaterial({color:rCol,transparent:true,opacity:.5})));
            /* Node spheres */
            [a1,a2].forEach(function(pos){
              var sp=new THREE.Mesh(new THREE.SphereGeometry(.12,6,6),mBB(rCol,.75));sp.position.copy(pos);helixGroup.add(sp);
            });
          }
          helixGroup.position.set(7,0,0);

          /* === NEURAL SPHERE (left side) === */
          var neural=new THREE.Group();scene.add(neural);
          var sphereR=4.5;var nodeCount=60;var nodes=[];
          for(var ni=0;ni<nodeCount;ni++){
            var phi=Math.acos(1-2*(ni+.5)/nodeCount);var theta=Math.PI*(1+Math.sqrt(5))*ni;
            var x=sphereR*Math.sin(phi)*Math.cos(theta),y=sphereR*Math.cos(phi),z=sphereR*Math.sin(phi)*Math.sin(theta);
            var sp2=new THREE.Mesh(new THREE.SphereGeometry(.1,6,6),mBB(ni%4===0?0xc9a96e:ni%4===1?0x8b5cf6:ni%4===2?0x4ecdc4:0xd4b87e,.8));
            sp2.position.set(x,y,z);neural.add(sp2);nodes.push(new THREE.Vector3(x,y,z));
          }
          /* Edges between near nodes */
          for(var a=0;a<nodeCount;a++){
            for(var b=a+1;b<nodeCount;b++){
              var dist=nodes[a].distanceTo(nodes[b]);
              if(dist<3.4){
                var eGeo=new THREE.BufferGeometry().setFromPoints([nodes[a],nodes[b]]);
                var op=1-dist/3.4;
                neural.add(new THREE.Line(eGeo,new THREE.LineBasicMaterial({color:0xc9a96e,transparent:true,opacity:op*.3})));
              }
            }
          }
          /* Shell rings */
          [[sphereR*.7,0xc9a96e,.28],[sphereR,.006,0x8b5cf6,.14],[sphereR*1.1,.004,0x4ecdc4,.09]].forEach(function(d,i){
            if(i===0){
              var g=new THREE.SphereGeometry(d[0],18,10);
              neural.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),new THREE.LineBasicMaterial({color:d[1],transparent:true,opacity:d[2]})));
            } else {
              var g2=new THREE.TorusGeometry(d[0],d[1],2,90);
              var m2=new THREE.Mesh(g2,mBB(d[2],d[3]));m2.rotation.x=Math.PI/2;neural.add(m2);
              var m3=m2.clone();m3.rotation.x=0;neural.add(m3);
            }
          });
          neural.position.set(-6,0,0);

          /* Large ambient particles */
          var pGeo=new THREE.BufferGeometry();
          var pPos=new Float32Array(1200*3);
          for(var i=0;i<1200;i++){var r=6+Math.random()*8,th=Math.random()*6.28,ph=Math.acos(2*Math.random()-1);pPos[i*3]=r*Math.sin(ph)*Math.cos(th);pPos[i*3+1]=r*Math.sin(ph)*Math.sin(th);pPos[i*3+2]=r*Math.cos(ph);}
          pGeo.setAttribute('position',new THREE.BufferAttribute(pPos,3));
          scene.add(new THREE.Points(pGeo,new THREE.PointsMaterial({color:0xc9a96e,size:.038,transparent:true,opacity:.36,sizeAttenuation:true})));

          var hmx=0,hmy=0,thmx=0,thmy=0;
          document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();thmx=(e.clientX-rc.left-rc.width/2)/(rc.width/2);thmy=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});

          var clk=new THREE.Clock();
          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            hmx+=(thmx-hmx)*.055;hmy+=(thmy-hmy)*.055;
            helixGroup.rotation.y=t*.22;
            neural.rotation.y=t*.08;neural.rotation.x=Math.sin(t*.12)*.08;
            p1.position.set(8+Math.sin(t*.42)*3,8+Math.cos(t*.32)*2.5,8);
            p2.position.set(-7+Math.cos(t*.36)*2.5,-5+Math.sin(t*.27)*2,7);
