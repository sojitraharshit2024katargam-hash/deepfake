            <!-- ── AUTHENTICATION ── -->
            <div class="doc-section" id="authentication">
                <div class="sec-eyebrow reveal">Security</div>
                <h2 class="sec-h reveal">Authentication</h2>
                <p class="sec-lead reveal" style="transition-delay:.06s">All API requests are authenticated using API keys passed in the <code style="color:var(--g)">X-API-Key</code> header. Keys are prefixed with <code style="color:var(--g)">nx_live_</code> for production and <code style="color:var(--g)">nx_test_</code> for sandbox environments.</p>

                <div class="callout info reveal" style="transition-delay:.08s"><i class="fa-solid fa-circle-info"></i><div>Keys are scoped to your account and inherit your plan's rate limits. Rotate keys anytime from the Dashboard without service interruption.</div></div>

                <div class="sdk-tabs reveal" style="transition-delay:.1s" id="AUTH_TABS">
                    <div class="sdk-tab on" onclick="switchTab('AUTH','curl')">cURL</div>
                    <div class="sdk-tab" onclick="switchTab('AUTH','python')">Python</div>
                    <div class="sdk-tab" onclick="switchTab('AUTH','node')">Node.js</div>
                    <div class="sdk-tab" onclick="switchTab('AUTH','php')">PHP</div>
                </div>
                <div class="sdk-content on" data-tab="AUTH" data-lang="curl">
                    <div class="code-wrap" style="margin-top:0;border-top:none">
                        <div class="code-header"><span class="code-lang"><i class="fa-solid fa-terminal"></i>cURL</span><button class="copy-btn" onclick="copyCode(this)"><i class="fa-regular fa-copy"></i> Copy</button></div>
                        <div class="code-body">
                            <span class="cm"># Add X-API-Key header to every request</span>
                            <span class="fn">curl</span> -X POST <span class="st">https://api.deepfake-nexus.io/v1/email/analyze</span> \
                            -H <span class="st">"X-API-Key: nx_live_YOUR_KEY_HERE"</span> \
                            -H <span class="st">"Content-Type: application/json"</span> \
                            -d <span class="st">'{"emailContent": "&lt;raw email string&gt;"}'</span>
                        </div>
                    </div>
                </div>
                <div class="sdk-content" data-tab="AUTH" data-lang="python">
                    <div class="code-wrap" style="margin-top:0;border-top:none">
                        <div class="code-header"><span class="code-lang"><i class="fa-brands fa-python"></i>Python</span><button class="copy-btn" onclick="copyCode(this)"><i class="fa-regular fa-copy"></i> Copy</button></div>
                        <div class="code-body">
                            <span class="kw">import</span> deepfake_nexus <span class="kw">as</span> nx

                            <span class="cm"># Initialize with your API key</span>
                            client = nx.<span class="fn">Client</span>(api_key=<span class="st">"nx_live_YOUR_KEY_HERE"</span>)

                            <span class="cm"># All methods inherit authentication automatically</span>
                            result = client.email.<span class="fn">analyze</span>(content=<span class="st">"&lt;raw email&gt;"</span>)
                            <span class="fn">print</span>(result.security_score)  <span class="cm"># 0-100</span>
                        </div>
                    </div>
                </div>
                <div class="sdk-content" data-tab="AUTH" data-lang="node">
                    <div class="code-wrap" style="margin-top:0;border-top:none">
                        <div class="code-header"><span class="code-lang"><i class="fa-brands fa-node-js"></i>Node.js</span><button class="copy-btn" onclick="copyCode(this)"><i class="fa-regular fa-copy"></i> Copy</button></div>
                        <div class="code-body">
                            <span class="kw">const</span> { <span class="tp">NexusClient</span> } = <span class="fn">require</span>(<span class="st">'@@deepfake-nexus/sdk'</span>);

                            <span class="kw">const</span> client = <span class="kw">new</span> <span class="tp">NexusClient</span>({
                            apiKey: <span class="st">'nx_live_YOUR_KEY_HERE'</span>,
                            environment: <span class="st">'production'</span> <span class="cm">// or 'sandbox'</span>
                            });

                            <span class="kw">const</span> result = <span class="kw">await</span> client.email.<span class="fn">analyze</span>({ content: <span class="st">'...'</span> });
                        </div>
                    </div>
                </div>
                <div class="sdk-content" data-tab="AUTH" data-lang="php">
                    <div class="code-wrap" style="margin-top:0;border-top:none">
                        <div class="code-header"><span class="code-lang"><i class="fa-brands fa-php"></i>PHP</span><button class="copy-btn" onclick="copyCode(this)"><i class="fa-regular fa-copy"></i> Copy</button></div>
                        <div class="code-body">
                            <span class="kw">use</span> DeepfakeNexus\Client;

                            <span class="kw">$</span>client = <span class="kw">new</span> <span class="tp">Client</span>([<span class="st">'api_key'</span> => <span class="st">'nx_live_YOUR_KEY_HERE'</span>]);
                            <span class="kw">$</span>result = <span class="kw">$</span>client->email-><span class="fn">analyze</span>([<span class="st">'emailContent'</span> => <span class="st">'...'</span>]);
                            echo <span class="kw">$</span>result[<span class="st">'securityScore'</span>];
                        </div>
                    </div>
                </div>

                <div class="callout warn reveal" style="transition-delay:.12s"><i class="fa-solid fa-triangle-exclamation"></i><div>Never commit API keys to version control. Use environment variables: <code style="color:var(--g)">NEXUS_API_KEY=nx_live_...</code></div></div>
