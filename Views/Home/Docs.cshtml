        .m-post {
            color: var(--ok);
            border-color: rgba(34,197,94,.4);
            background: rgba(34,197,94,.08)
        }

        .m-get {
            color: var(--teal);
            border-color: rgba(78,205,196,.4);
            background: rgba(78,205,196,.08)
        }

        .m-del {
            color: var(--red);
            border-color: rgba(255,68,102,.4);
            background: rgba(255,68,102,.08)
        }

        .ep-path {
            font-family: 'DM Mono',monospace;
            font-size: 11px;
            color: var(--c);
            letter-spacing: .04em;
            flex: 1
        }

        .ep-desc {
            font-family: 'DM Mono',monospace;
            font-size: 8.5px;
            color: var(--c4);
            letter-spacing: .06em
        }

        .ep-body {
            padding: 18px 20px;
            border-top: 1px solid var(--s);
            font-family: 'DM Mono',monospace;
            font-size: 9.5px;
            color: var(--c3);
            line-height: 1.8
        }

        .param-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px
        }

            .param-table th {
                text-align: left;
                font-size: 8px;
                letter-spacing: .16em;
                text-transform: uppercase;
                color: var(--g);
                padding: 8px 12px;
                border-bottom: 1px solid var(--s)
            }

            .param-table td {
                padding: 10px 12px;
                border-bottom: 1px solid rgba(237,233,224,.04);
                font-size: 9px;
                vertical-align: top
            }

                .param-table td:first-child {
                    color: var(--c2);
                    font-weight: 500
                }

                .param-table td:nth-child(2) {
                    color: var(--pur)
                }

                .param-table td:last-child {
                    color: var(--c4)
                }

        .req-badge {
            font-size: 7px;
            padding: 2px 6px;
            border: 1px solid rgba(255,68,102,.4);
            color: var(--red);
            background: rgba(255,68,102,.07);
            letter-spacing: .08em;
            margin-left: 6px
        }

        .opt-badge {
            font-size: 7px;
            padding: 2px 6px;
            border: 1px solid var(--s);
            color: var(--c4);
            letter-spacing: .08em;
            margin-left: 6px
        }

        /* ── Response schema ── */
        .schema-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: var(--s);
            border: 1px solid var(--s);
            margin: 16px 0
        }

        .schema-cell {
            background: var(--ink);
            padding: 20px 22px
        }

        .schema-cell-title {
            font-family: 'DM Mono',monospace;
            font-size: 8px;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--g);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .schema-cell-title::before {
                content: '';
                width: 12px;
                height: 1px;
                background: var(--g2)
            }

        /* ── 3D inline canvases ── */
        .inline-3d {
            width: 100%;
            overflow: hidden;
            position: relative;
            border: 1px solid var(--s);
            background: rgba(0,0,0,.3)
        }

            .inline-3d canvas {
                width: 100% !important;
                height: 100% !important;
                display: block
            }

        .inline-3d-over {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 2
        }

        .i3d-corner {
            position: absolute;
            width: 10px;
            height: 10px;
            border-color: var(--g2);
            border-style: solid
        }

        .i3d-tl {
            top: 8px;
            left: 8px;
            border-width: 1px 0 0 1px
        }

        .i3d-tr {
            top: 8px;
            right: 8px;
            border-width: 1px 1px 0 0
        }

        .i3d-bl {
            bottom: 8px;
            left: 8px;
            border-width: 0 0 1px 1px
        }

        .i3d-br {
            bottom: 8px;
            right: 8px;
            border-width: 0 1px 1px 0
        }

        .i3d-lbl {
            position: absolute;
            font-family: 'DM Mono',monospace;
            font-size: 7.5px;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--g);
            padding: 3px 8px;
            border: 1px solid var(--g3);
            background: rgba(4,4,10,.78)
        }

            .i3d-lbl.tl {
                top: 6px;
                left: 24px
            }

            .i3d-lbl.br {
                bottom: 6px;
                right: 24px
            }

        /* ── Alert / callout boxes ── */
        .callout {
            padding: 14px 18px;
            border-left: 2px solid;
            margin: 16px 0;
            font-family: 'DM Mono',monospace;
            font-size: 9.5px;
            line-height: 1.8;
            letter-spacing: .04em;
            display: flex;
            gap: 12px;
            align-items: flex-start
        }

            .callout.info {
                border-color: var(--teal);
                background: rgba(78,205,196,.05);
                color: var(--c3)
            }

            .callout.warn {
                border-color: var(--warn);
                background: rgba(245,158,11,.05);
                color: var(--c3)
            }

            .callout.tip {
                border-color: var(--ok);
                background: rgba(34,197,94,.05);
                color: var(--c3)
            }

            .callout i {
                flex-shrink: 0;
                margin-top: 1px;
                font-size: 11px
            }

            .callout.info i {
                color: var(--teal)
            }

            .callout.warn i {
                color: var(--warn)
            }

            .callout.tip i {
                color: var(--ok)
            }

        /* ── Steps ── */
        .steps {
            display: flex;
            flex-direction: column;
            gap: 0;
            margin: 20px 0;
            border: 1px solid var(--s)
        }

        .step {
            display: grid;
            grid-template-columns: 52px 1fr;
            border-bottom: 1px solid var(--s);
            transition: background .3s
        }

            .step:last-child {
                border-bottom: none
            }

            .step:hover {
                background: rgba(201,169,110,.025)
            }

        .step-num {
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Instrument Serif',serif;
            font-size: 26px;
            font-style: italic;
            color: var(--g);
            border-right: 1px solid var(--s);
            background: rgba(201,169,110,.03)
        }

        .step-body {
            padding: 18px 22px
        }

        .step-title {
            font-family: 'Syne',sans-serif;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: -.01em
        }

        .step-desc {
            font-family: 'DM Mono',monospace;
            font-size: 9px;
            color: var(--c3);
            line-height: 1.85;
            letter-spacing: .04em
        }

        /* ── SDK tabs ── */
        .sdk-tabs {
            display: flex;
            gap: 0;
            border: 1px solid var(--s);
            border-bottom: none
        }

        .sdk-tab {
            padding: 9px 18px;
            font-family: 'DM Mono',monospace;
            font-size: 8.5px;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--c4);
            cursor: none;
            border-right: 1px solid var(--s);
            transition: all .3s;
            border-bottom: 2px solid transparent
        }

            .sdk-tab:last-child {
                border-right: none
            }

            .sdk-tab.on {
                color: var(--g);
                border-bottom-color: var(--g);
                background: rgba(201,169,110,.05)
            }

        .sdk-content {
            border: 1px solid var(--s);
            display: none
        }

            .sdk-content.on {
                display: block
            }

        /* ── Rate limit table ── */
        .rl-table {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid var(--s);
            margin: 16px 0
        }

            .rl-table th {
                padding: 12px 18px;
                text-align: left;
                font-family: 'DM Mono',monospace;
                font-size: 8px;
                letter-spacing: .16em;
                text-transform: uppercase;
                color: var(--g);
                border-bottom: 1px solid var(--s);
                background: rgba(201,169,110,.03)
            }

            .rl-table td {
                padding: 12px 18px;
                font-family: 'DM Mono',monospace;
                font-size: 9.5px;
                color: var(--c3);
                border-bottom: 1px solid rgba(237,233,224,.04)
            }

            .rl-table tr:hover td {
                background: rgba(201,169,110,.02)
            }

        .tier-badge {
            display: inline-flex;
            padding: 2px 8px;
            font-size: 7.5px;
            letter-spacing: .1em;
            border: 1px solid;
            font-family: 'DM Mono',monospace
        }

        .t-free {
            color: var(--c3);
            border-color: var(--s)
        }

        .t-pro {
            color: var(--g);
            border-color: var(--g3)
        }

        .t-ent {
            color: var(--pur);
            border-color: rgba(139,92,246,.4)
        }

        /* ── TOC right ── */
        .toc-float {
            position: fixed;
            right: 28px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 80;
            display: flex;
            flex-direction: column;
            gap: 0
        }

        .toc-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            border: 1px solid var(--c4);
            transition: all .3s var(--ease);
            cursor: none;
            position: relative
        }

            .toc-dot:hover {
                border-color: var(--g);
                background: var(--g2)
            }

            .toc-dot.on {
                border-color: var(--g);
                background: var(--g);
                box-shadow: 0 0 10px var(--g2)
            }

            .toc-dot::after {
                content: attr(data-label);
                position: absolute;
                right: 14px;
                top: 50%;
                transform: translateY(-50%);
                font-family: 'DM Mono',monospace;
                font-size: 7.5px;
                letter-spacing: .1em;
                text-transform: uppercase;
                color: var(--g);
                white-space: nowrap;
                opacity: 0;
                transition: opacity .2s;
                pointer-events: none;
                background: rgba(4,4,10,.9);
                padding: 3px 8px;
                border: 1px solid var(--g3)
            }

            .toc-dot:hover::after {
                opacity: 1
            }

        .toc-line {
            width: 1px;
            height: 20px;
            background: var(--s);
            margin: 4px auto
        }

        /* ── Scroll reveal ── */
        .reveal {
            opacity: 0;
            transform: translateY(22px);
            transition: opacity .75s var(--ease),transform .75s var(--ease)
        }

            .reveal.vis {
                opacity: 1;
                transform: none
            }

        /* ── Toast ── */
        .toast-wrap {
            position: fixed;
            right: 18px;
            bottom: 18px;
            z-index: 3000;
            display: grid;
            gap: 7px;
            width: min(320px,calc(100vw-36px))
        }

        .toastx {
            border: 1px solid var(--s);
            background: rgba(4,4,10,.96);
            backdrop-filter: blur(24px);
            padding: 12px 14px;
            display: grid;
            grid-template-columns: auto 1fr auto;
            gap: 10px;
            align-items: center;
            position: relative;
            overflow: hidden;
            animation: TI .35s var(--ease)
        }

            .toastx::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg,transparent,var(--g),transparent)
            }
        @@keyframes TI {
            from {
                transform: translateX(8px);
                opacity: 0
            }

            to {
                transform: translateX(0);
                opacity: 1
            }
        }

        .t-ic2 {
            width: 28px;
            height: 28px;
            border: 1px solid var(--g3);
            display: grid;
            place-items: center;
            font-size: 10px
        }

        .t-h {
            font-size: 11px;
            font-weight: 700
        }

        .t-p {
            font-family: 'DM Mono',monospace;
            font-size: 8px;
            color: var(--c3);
            margin-top: 1px
        }

        .t-x2 {
            background: none;
            border: none;
            cursor: none;
            color: var(--c4);
            font-size: 11px;
            padding: 3px;
            transition: color .2s
        }

            .t-x2:hover {
                color: var(--c)
            }

        ::selection {
            background: rgba(201,169,110,.18);
            color: var(--c)
        }

        ::-webkit-scrollbar {
            width: 4px
        }

        ::-webkit-scrollbar-track {
            background: rgba(4,4,10,.8)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--g2)
        }

        @@media(max - width:1100px) {
            .docs-layout {
                grid-template-columns: 1fr
            }

            .sidebar {
                position: relative;
                top: 0;
                height: auto;
                border-right: none;
                border-bottom: 1px solid var(--s)
            }

            .qs-grid {
                grid-template-columns: 1fr 1fr
            }

            .toc-float {
                display: none
            }
        }
        @@media(max - width:680px) {
            .qs-grid {
                grid-template-columns: 1fr
            }

            .doc-section {
                padding: 40px 24px
            }

            .hero-content {
                padding: 0 28px
            }

            .schema-row {
                grid-template-columns: 1fr
            }

            .search-tags {
                display: none
            }
        }
    </style>
</head>
