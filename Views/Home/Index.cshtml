                <article class="mcard rv d1"><div class="mcard-br tl"></div><div class="mcard-br tr"></div><div class="mcard-br bl"></div><div class="mcard-br br2"></div><div class="mcard-n"><span>04 / Scam Detection</span><span>&#8599;</span></div><div class="mcard-ic">&#9678;</div><h3 class="mcard-h">Scam Detection</h3><p class="mcard-p">Behavioral risk scoring for voice, chat, and video scams — focused on social engineering patterns and identity verification signals.</p><div class="mcard-tags"><span class="mcard-tag">Voice-Clone Signals</span><span class="mcard-tag">Conversation Heuristics</span><span class="mcard-tag">Risk Policy Rules</span></div><div class="mcard-arr">&#8594;</div></article>
