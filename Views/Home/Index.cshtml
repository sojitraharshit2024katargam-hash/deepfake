    <script>
        (function(){
        'use strict';

        // LOADER
        var fill=document.getElementById('ld-fill'),pctEl=document.getElementById('ld-pct'),pct=0;
        var ldT=setInterval(function(){
          pct+=Math.floor(Math.random()*14)+5;if(pct>=100){pct=100;clearInterval(ldT);setTimeout(function(){document.getElementById('loader').classList.add('out');},400);}
          if(fill)fill.style.width=pct+'%';if(pctEl)pctEl.textContent=pct+'%';
        },70);

        // CURSOR
        var cur=document.getElementById('cur'),curR=document.getElementById('cur-r'),mx=0,my=0,rx=0,ry=0;
        document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
        (function L(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;curR.style.left=rx+'px';curR.style.top=ry+'px';requestAnimationFrame(L);})();
        document.querySelectorAll('a,button,.mcard,.faq-q,.uc-card,.st,.pr-card').forEach(function(el){
          el.addEventListener('mouseenter',function(){curR.style.width='52px';curR.style.height='52px';curR.style.borderColor='rgba(201,169,110,.9)';});
          el.addEventListener('mouseleave',function(){curR.style.width='30px';curR.style.height='30px';curR.style.borderColor='rgba(201,169,110,.4)';});
        });

        // SCROLL REVEAL
        var io=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('on');io.unobserve(x.target);}});},{threshold:.07});
        document.querySelectorAll('.rv').forEach(function(el){io.observe(el);});

        // HUD PIPS
        var pips=[0,1,2,3,4,5].map(function(i){return document.getElementById('hp'+i);});
        window.addEventListener('scroll',function(){
          var sp=window.scrollY/Math.max(1,document.body.scrollHeight-window.innerHeight);
          var a=Math.min(5,Math.floor(sp*6));
          pips.forEach(function(p,i){if(p)p.classList.toggle('a',i===a);});
        },{passive:true});

        // COUNTERS
        function animCount(el){
          var v=parseFloat(el.dataset.v),isF=String(v).includes('.');
          var dur=1700,s=performance.now();
          (function tk(now){var t=Math.min(1,(now-s)/dur),e2=1-Math.pow(1-t,4);el.textContent=isF?(v*e2).toFixed(1):Math.round(v*e2);if(t<1)requestAnimationFrame(tk);})(performance.now());
        }
        var cio=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){animCount(x.target);cio.unobserve(x.target);}});},{threshold:.4});
        document.querySelectorAll('.cnt').forEach(function(el){cio.observe(el);});

        // FAQ
        document.querySelectorAll('.faq-q').forEach(function(q){
          q.addEventListener('click',function(){var item=q.closest('.faq-item'),op=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(function(f){f.classList.remove('open');});if(!op)item.classList.add('open');});
        });

        // SMOOTH SCROLL
        document.querySelectorAll('a[href^="#"]').forEach(function(a){
          a.addEventListener('click',function(e){var el=document.querySelector(a.getAttribute('href'));if(!el)return;e.preventDefault();el.scrollIntoView({behavior:'smooth',block:'start'});});
        });

        // THREE INIT
        function initThree(){
          if(typeof THREE==='undefined'){setTimeout(initThree,120);return;}
          startBg();startShowcase();
        }

        function startBg(){
          var canvas=document.getElementById('bg-canvas');
          var W=function(){return window.innerWidth;},H=function(){return window.innerHeight;};
          var renderer=new THREE.WebGLRenderer({canvas:canvas,antialias:true,alpha:true,powerPreference:'high-performance'});
          renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));renderer.setSize(W(),H());
          renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=.9;
          var scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x04040a,.02);
          var camera=new THREE.PerspectiveCamera(58,W()/H(),.1,400);camera.position.set(0,0,20);

          // Lights
          scene.add(new THREE.AmbientLight(0x06060e,2.5));
          var kL=new THREE.SpotLight(0xc9a96e,18,90,Math.PI/6,.35,1.2);kL.position.set(16,20,14);scene.add(kL);
          var fL=new THREE.SpotLight(0x4ecdc4,8,65,Math.PI/5,.4,1.5);fL.position.set(-18,9,10);scene.add(fL);
          var bL=new THREE.SpotLight(0x8b5cf6,5,50,Math.PI/4,.5,2);bL.position.set(-10,-10,8);scene.add(bL);
          var p1=new THREE.PointLight(0xc9a96e,5,35);scene.add(p1);
          var p2=new THREE.PointLight(0x4ecdc4,3,28);scene.add(p2);
          var p3=new THREE.PointLight(0x8b5cf6,2.5,20);scene.add(p3);
          var p4=new THREE.PointLight(0xffe8dd,2,24);scene.add(p4);

          function gM(c,op,r){return new THREE.MeshPhysicalMaterial({color:c||0xc9a96e,metalness:.95,roughness:r||.04,transparent:true,opacity:op||.07,side:THREE.DoubleSide,transmission:.88,thickness:.5,ior:1.5});}
          function dM(){return new THREE.MeshPhysicalMaterial({color:0x0c0a14,metalness:.92,roughness:.08,transparent:true,opacity:.15,side:THREE.DoubleSide,transmission:.8,thickness:.6,ior:1.42});}
          function wM(c,op){return new THREE.MeshBasicMaterial({color:c||0xc9a96e,wireframe:true,transparent:true,opacity:op||.08});}
          function eM(c,op){return new THREE.LineBasicMaterial({color:c||0xc9a96e,transparent:true,opacity:op||.22});}

          var objs=[];
          function addBox(x,y,z,s,mat){
            var g=new THREE.BoxGeometry(1,1,1,2,2,2),m=new THREE.Mesh(g,mat);
            m.scale.setScalar(s);m.position.set(x,y,z);
            m.rotation.set(Math.random()*6.28,Math.random()*6.28,Math.random()*6.28);
            m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eM(0xc9a96e,.24)));
            scene.add(m);
            objs.push({m:m,ox:x,oy:y,oz:z,fp:Math.random()*6.28,fs:.25+Math.random()*.25,rs:{x:(Math.random()-.5)*.005,y:(Math.random()-.5)*.005,z:(Math.random()-.5)*.003},layer:Math.floor(Math.random()*3)});
          }

          // Hero foreground — big cubes
          addBox(5,2,-1,3.8,gM(0xc9a96e,.07,.04));addBox(-4.5,-1.5,-.5,3.2,gM(0x8ed4d0,.06,.05));
          addBox(1,4.5,-4,5.2,dM());addBox(-1.5,-4.8,-2.5,3,gM(0xd4b87e,.06,.06));
          addBox(7,-3.5,-5.5,2.5,new THREE.MeshStandardMaterial({color:0x1c1820,metalness:1,roughness:.05}));
          addBox(-7.5,4,-6,2.8,gM(0xc9a96e,.05,.03));addBox(3.5,-7,-4,2,wM(0xc9a96e,.15));addBox(-3,7,-4,2.2,wM(0x4ecdc4,.12));
          // Mid layer
          for(var i=0;i<18;i++){addBox((Math.random()-.5)*28,(Math.random()-.5)*17,-7-Math.random()*8,.8+Math.random()*1.8,i%3===0?dM():i%3===1?wM(0xc9a96e,.07):gM(0xc9a96e,.04));}
          // Deep bg
          for(var j=0;j<40;j++){addBox((Math.random()-.5)*44,(Math.random()-.5)*24,-14-Math.random()*20,.1+Math.random()*.45,wM(0xc9a96e,.04+Math.random()*.04));}

          // Tori
          var tori=[];
          var td=[{r:1.8,tb:.008,c:0xc9a96e,op:.28,x:3,y:2,z:-2,rx:1.05,rz:.2},{r:3,tb:.005,c:0x4ecdc4,op:.2,x:-5,y:-2,z:-3,rx:.78,rz:0},{r:2.4,tb:.006,c:0xc9a96e,op:.16,x:8,y:5,z:-7,rx:.62,rz:.3},{r:4,tb:.004,c:0x4ecdc4,op:.13,x:-7,y:6,z:-6,rx:.52,rz:0},{r:1.5,tb:.01,c:0x8b5cf6,op:.2,x:0,y:-5,z:-3,rx:1.57,rz:.62},{r:5,tb:.003,c:0xc9a96e,op:.09,x:12,y:0,z:-10,rx:.2,rz:1.05},{r:2.8,tb:.005,c:0x8b5cf6,op:.14,x:-10,y:-7,z:-8,rx:1.05,rz:.78},{r:3.5,tb:.004,c:0x4ecdc4,op:.11,x:-2,y:9,z:-9,rx:.5,rz:.2},{r:2.2,tb:.007,c:0xd4b87e,op:.17,x:6,y:-5,z:-5,rx:.4,rz:.5},{r:6,tb:.003,c:0xc9a96e,op:.07,x:-14,y:3,z:-12,rx:.3,rz:.4}];
          td.forEach(function(d){
            var g=new THREE.TorusGeometry(d.r,d.tb,2,80),m=new THREE.Mesh(g,new THREE.MeshBasicMaterial({color:d.c,transparent:true,opacity:d.op}));
            m.rotation.set(d.rx,0,d.rz);m.position.set(d.x,d.y,d.z);scene.add(m);
            tori.push({m:m,rs:.003+Math.random()*.004,ox:d.x,oy:d.y,oz:d.z,fp:Math.random()*6.28,fs:.2+Math.random()*.25,layer:Math.floor(Math.random()*3)});
          });

          // Octahedra
          var octas=[];
          for(var k=0;k<14;k++){
            var og=new THREE.OctahedronGeometry(.4+Math.random()*.9,0);
            var om=new THREE.LineSegments(new THREE.EdgesGeometry(og),eM(k%3===0?0x8b5cf6:k%2===0?0xc9a96e:0x4ecdc4,.18));
            om.position.set((Math.random()-.5)*26,(Math.random()-.5)*16,-5-Math.random()*13);scene.add(om);
            octas.push({m:om,rs:{x:.005+Math.random()*.005,y:.006+Math.random()*.004,z:.003},ox:om.position.x,oy:om.position.y,oz:om.position.z,fp:Math.random()*6.28,fs:.2+Math.random()*.3,layer:Math.floor(Math.random()*3)});
          }

          // Icosahedra
          var icos=[];
          for(var n=0;n<10;n++){
            var ig=new THREE.IcosahedronGeometry(.3+Math.random()*.8,1);
            var im=new THREE.LineSegments(new THREE.EdgesGeometry(ig),eM(n%3===0?0x8b5cf6:n%2===0?0xc9a96e:0x4ecdc4,.14));
            im.position.set((Math.random()-.5)*30,(Math.random()-.5)*18,-7-Math.random()*15);scene.add(im);
            icos.push({m:im,rs:{x:.003,y:.007,z:.004},ox:im.position.x,oy:im.position.y,oz:im.position.z,fp:Math.random()*6.28,fs:.18+Math.random()*.28,layer:Math.floor(Math.random()*3)});
          }

          // Dodecahedra
          var dodecs=[];
          for(var q=0;q<8;q++){
            var dg=new THREE.DodecahedronGeometry(.35+Math.random()*.6,0);
            var dm=new THREE.LineSegments(new THREE.EdgesGeometry(dg),eM(q%2===0?0xd4b87e:0x8b5cf6,.13));
            dm.position.set((Math.random()-.5)*24,(Math.random()-.5)*15,-6-Math.random()*11);scene.add(dm);
            dodecs.push({m:dm,rs:{x:.006,y:.004,z:.005},fp:Math.random()*6.28,fs:.22+Math.random()*.28});
          }

          // Constellation ring
          var ring=[];
          for(var r2=0;r2<16;r2++){
            var ang=r2/16*6.28,rad=10+Math.random()*2;
            var cs=.15+Math.random()*.45;
            var cg=new THREE.BoxGeometry(cs,cs,cs,1,1,1);
            var cm=new THREE.LineSegments(new THREE.EdgesGeometry(cg),eM(r2%3===0?0x8b5cf6:r2%2===0?0xc9a96e:0x4ecdc4,.18));
            cm.position.set(Math.cos(ang)*rad,Math.sin(ang)*rad*.4,-13-Math.random()*4);scene.add(cm);
            ring.push({m:cm,ang:ang,rad:rad,rs:{x:.006,y:.008},fp:Math.random()*6.28,fs:.28+Math.random()*.2});
          }

          // Particles
          function mkP(n,spread,zMin,zSpr,col,sz,op){
            var g=new THREE.BufferGeometry(),pos=new Float32Array(n*3);
            for(var ii=0;ii<n;ii++){pos[ii*3]=(Math.random()-.5)*spread;pos[ii*3+1]=(Math.random()-.5)*spread*.55;pos[ii*3+2]=zMin-Math.random()*zSpr;}
            g.setAttribute('position',new THREE.BufferAttribute(pos,3));
            var pts=new THREE.Points(g,new THREE.PointsMaterial({color:col,size:sz,transparent:true,opacity:op,sizeAttenuation:true}));
            scene.add(pts);return pts;
          }
          var pA=mkP(800,65,4,28,0xc9a96e,.038,.32),pB=mkP(140,28,2,12,0xd4b87e,.085,.48),pC=mkP(100,22,2,9,0x4ecdc4,.065,.4),pD=mkP(70,20,2,7,0x8b5cf6,.055,.35);

          var tmx=0,tmy=0,cmx=0,cmy=0,scrollY=0,lastSY=0,sVel=0;
          document.addEventListener('mousemove',function(e){tmx=(e.clientX/window.innerWidth-.5)*2;tmy=-(e.clientY/window.innerHeight-.5)*2;});
          window.addEventListener('scroll',function(){scrollY=window.scrollY;},{passive:true});
          window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});

          var clock=new THREE.Clock();
          function lerp(a,b,t){return a+(b-a)*t;}

          function tick(){
            requestAnimationFrame(tick);
            var t=clock.getElapsedTime();
            sVel=scrollY-lastSY;lastSY=scrollY;
            cmx+=(tmx-cmx)*.016;cmy+=(tmy-cmy)*.016;
            var sp=Math.min(1,scrollY/Math.max(1,document.body.scrollHeight-window.innerHeight));
            var xSpin=Math.abs(sVel)*.012;

            // Camera
            camera.position.x=lerp(camera.position.x,cmx*2.6,.055);
            camera.position.y=lerp(camera.position.y,cmy*1.7+sp*-5,.055);
            camera.position.z=lerp(camera.position.z,20-sp*13,.055);
            camera.fov=lerp(camera.fov,58+sp*14,.04);camera.updateProjectionMatrix();
            camera.lookAt(cmx*.6,cmy*.4+scrollY*.004,-sp*7);

            // Lights
            p1.position.set(7+Math.sin(t*.4)*4,7+Math.cos(t*.3)*3,6);p2.position.set(-8+Math.cos(t*.35)*3,-5+Math.sin(t*.28)*2.5,7);
            p3.position.set(-4+Math.cos(t*.28)*4,3+Math.sin(t*.2)*3,-2);p4.position.set(Math.sin(t*.22)*5,Math.cos(t*.3)*5,9);
            kL.intensity=18+Math.sin(t*.2)*5;fL.intensity=8+Math.sin(t*.25+1)*2.5;bL.intensity=5+Math.sin(t*.18+2)*2;

            // Cubes — layered scroll response
            objs.forEach(function(o){
              var lm=[1,1.6,2.8][o.layer];
              o.m.rotation.x+=o.rs.x*(1+xSpin*lm);o.m.rotation.y+=o.rs.y*(1+xSpin*lm);o.m.rotation.z+=o.rs.z;
              o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.42;
              o.m.position.x=o.ox+Math.cos(t*o.fs*.7+o.fp)*.24+cmx*(.3*lm);
              o.m.position.z=lerp(o.m.position.z,o.oz-sp*(3+o.layer*3),.04);
            });

            // Tori
            tori.forEach(function(o){
              o.m.rotation.z+=o.rs*(1+xSpin*.5);o.m.rotation.y+=o.rs*.7;o.m.rotation.x+=o.rs*.3;
              o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.3;
              o.m.position.z=lerp(o.m.position.z,o.oz-sp*(2+o.layer*2),.04);
            });

            // Octahedra
            octas.forEach(function(o){
              o.m.rotation.x+=o.rs.x*(1+xSpin);o.m.rotation.y+=o.rs.y*(1+xSpin);o.m.rotation.z+=o.rs.z;
              o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.26;
              o.m.position.z=lerp(o.m.position.z,o.oz-sp*(1+o.layer*1.5),.04);
            });

            // Icosahedra
            icos.forEach(function(o){
              o.m.rotation.x+=o.rs.x;o.m.rotation.y+=o.rs.y*(1+xSpin*.8);
              o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.2;
              o.m.position.z=lerp(o.m.position.z,o.oz-sp*(1+o.layer*1.2),.04);
            });

            // Dodecahedra
            dodecs.forEach(function(o){o.m.rotation.x+=o.rs.x;o.m.rotation.y+=o.rs.y;o.m.rotation.z+=o.rs.z;});

            // Constellation ring — orbits + scroll
            ring.forEach(function(o){
              o.ang+=.0018+xSpin*.004;
              o.m.position.x=Math.cos(o.ang)*o.rad*(1+sp*.4);
              o.m.position.y=Math.sin(o.ang)*o.rad*.4*(1+sp*.25);
              o.m.position.z=lerp(o.m.position.z,-13-sp*10,.04);
              o.m.rotation.x+=o.rs.x*(1+xSpin);o.m.rotation.y+=o.rs.y;
            });

            // Particles
            pA.rotation.y=t*.007;pA.rotation.x=sp*.45;
            pB.rotation.y=-t*.012;pB.rotation.z=sp*.32;
            pC.rotation.y=t*.015;pC.position.z=lerp(pC.position.z,-sp*6,.04);
            pD.rotation.z=-t*.01;pD.rotation.x=sp*.5;pD.position.y=lerp(pD.position.y,sp*3,.04);

            renderer.render(scene,camera);
          }
          tick();
        }

        function startShowcase(){
          var canvas=document.getElementById('sc');if(!canvas)return;
          var wrap=canvas.parentElement;
          function sz(){return{w:wrap.offsetWidth,h:wrap.offsetHeight};}
          var s=sz();
          var renderer=new THREE.WebGLRenderer({canvas:canvas,antialias:true,alpha:true,powerPreference:'high-performance'});
          renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));renderer.setSize(s.w,s.h);
          renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.2;
          var scene=new THREE.Scene(),camera=new THREE.PerspectiveCamera(52,s.w/s.h,.1,100);
          camera.position.set(0,0,9);
          scene.add(new THREE.AmbientLight(0x06060e,1.5));
          var sl1=new THREE.SpotLight(0xc9a96e,16,45,Math.PI/5,.3,1.2);sl1.position.set(8,13,9);scene.add(sl1);
          var sl2=new THREE.SpotLight(0x4ecdc4,10,36,Math.PI/4,.4,1.5);sl2.position.set(-9,6,7);scene.add(sl2);
          var sl3=new THREE.SpotLight(0x8b5cf6,6,30,Math.PI/3,.5,1.8);sl3.position.set(-4,-10,8);scene.add(sl3);
          var sp1=new THREE.PointLight(0xc9a96e,6,25);scene.add(sp1);var sp2=new THREE.PointLight(0x4ecdc4,4,20);scene.add(sp2);var sp3=new THREE.PointLight(0x8b5cf6,3,18);scene.add(sp3);

          function mkC(sz2,ec,eo){
            var g=new THREE.BoxGeometry(sz2,sz2,sz2,3,3,3);
            var m=new THREE.Mesh(g,new THREE.MeshPhysicalMaterial({color:0x10091a,metalness:.96,roughness:.03,transparent:true,opacity:.07,side:THREE.DoubleSide,transmission:.9,thickness:.8,ior:1.6}));
            m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),new THREE.LineBasicMaterial({color:ec,transparent:true,opacity:eo})));
            scene.add(m);return m;
          }
          var cA=mkC(3.2,0xc9a96e,.7),cB=mkC(2.0,0x4ecdc4,.62),cC=mkC(1.1,0xd4b87e,.75);
          var cD=new THREE.Mesh(new THREE.BoxGeometry(.45,.45,.45,1,1,1),new THREE.MeshStandardMaterial({color:0xc9a96e,metalness:.99,roughness:.01}));
          cD.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.BoxGeometry(.45,.45,.45)),new THREE.LineBasicMaterial({color:0xfff0cc,transparent:true,opacity:.95})));
          scene.add(cD);

          // Orbiters — 9
          var orbs=[];
          [{r:4.2,sp:.42,ph:0,sz:'.7',c:0x4ecdc4,ti:.5},{r:3.5,sp:.58,ph:2.2,sz:'.48',c:0xc9a96e,ti:.7},
           {r:5.0,sp:.32,ph:4.4,sz:'.82',c:0xc9a96e,ti:.3},{r:3.0,sp:.72,ph:1.1,sz:'.4',c:0x4ecdc4,ti:.9},
           {r:5.5,sp:.26,ph:3.6,sz:'.58',c:0xd4b87e,ti:.4},{r:4.0,sp:.48,ph:5.8,sz:'.44',c:0x4ecdc4,ti:.6},
           {r:4.5,sp:.37,ph:2.8,sz:'.62',c:0xc9a96e,ti:.55},{r:2.8,sp:.82,ph:.8,sz:'.35',c:0x8b5cf6,ti:.8},
           {r:6.0,sp:.22,ph:4.0,sz:'.72',c:0x8b5cf6,ti:.35}].forEach(function(d){
            var sz2=parseFloat(d.sz);
            var g=new THREE.BoxGeometry(sz2,sz2,sz2,2,2,2),m=new THREE.Mesh(g,new THREE.MeshPhysicalMaterial({color:0x12101c,metalness:.9,roughness:.07,transparent:true,opacity:.13,transmission:.75,side:THREE.DoubleSide}));
            m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),new THREE.LineBasicMaterial({color:d.c,transparent:true,opacity:.55})));
            scene.add(m);orbs.push({m:m,r:d.r,sp:d.sp,ph:d.ph,ti:d.ti});
          });

          // Rings — 7
          var sRings=[];
          [{r:3.2,tb:.006,c:0xc9a96e,op:.35,rx:1.05,rz:0,rs:.006},{r:4.0,tb:.004,c:0x4ecdc4,op:.24,rx:.78,rz:.78,rs:.0045},{r:5.0,tb:.003,c:0xc9a96e,op:.15,rx:.62,rz:.62,rs:.003},{r:2.4,tb:.007,c:0x4ecdc4,op:.22,rx:1.57,rz:.52,rs:.007},{r:6.0,tb:.002,c:0xd4b87e,op:.1,rx:.52,rz:1.05,rs:.002},{r:3.6,tb:.005,c:0x8b5cf6,op:.18,rx:.4,rz:.6,rs:.005},{r:4.8,tb:.003,c:0x8b5cf6,op:.12,rx:.7,rz:.78,rs:.0035}].forEach(function(d){
            var g=new THREE.TorusGeometry(d.r,d.tb,2,100),m=new THREE.Mesh(g,new THREE.MeshBasicMaterial({color:d.c,transparent:true,opacity:d.op}));
            m.rotation.x=d.rx;m.rotation.z=d.rz;scene.add(m);sRings.push({m:m,rs:d.rs});
          });

          // Icosa shells — 3
          [[2.4,.065,0xc9a96e],[3.6,.038,0x4ecdc4],[5,.022,0x8b5cf6]].forEach(function(d){
            var g=new THREE.IcosahedronGeometry(d[0],1);
            scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),new THREE.LineBasicMaterial({color:d[2],transparent:true,opacity:d[1]})));
          });

          // Octahedra orbiters — 5
          var sOctas=[];
          for(var si=0;si<5;si++){
            var sg=new THREE.OctahedronGeometry(.28+si*.1,0);
            var sm=new THREE.LineSegments(new THREE.EdgesGeometry(sg),new THREE.LineBasicMaterial({color:si%2===0?0xc9a96e:0x4ecdc4,transparent:true,opacity:.35}));
            scene.add(sm);sOctas.push({m:sm,r:3.5+si*.6,sp:.6+si*.12,ph:si*1.26,ti:.4+si*.12});
          }

          // Particles
          function mkSP(n,minR,maxR,col,sz,op){
            var g=new THREE.BufferGeometry(),pos=new Float32Array(n*3);
            for(var ii=0;ii<n;ii++){
              var r=minR+Math.random()*(maxR-minR),th=Math.random()*6.28,ph=Math.acos(2*Math.random()-1);
              pos[ii*3]=r*Math.sin(ph)*Math.cos(th);pos[ii*3+1]=r*Math.sin(ph)*Math.sin(th);pos[ii*3+2]=r*Math.cos(ph);
            }
            g.setAttribute('position',new THREE.BufferAttribute(pos,3));
            var pts=new THREE.Points(g,new THREE.PointsMaterial({color:col,size:sz,transparent:true,opacity:op,sizeAttenuation:true}));
            scene.add(pts);return pts;
          }
          var spPts=mkSP(380,3,6.5,0xc9a96e,.04,.65);
          var cPts=mkSP(120,4,5.2,0x4ecdc4,.05,.48);
          var purPts=mkSP(80,3,4.5,0x8b5cf6,.045,.42);

          // Equatorial ring particles
          var eqG=new THREE.BufferGeometry(),eqPos=new Float32Array(140*3);
          for(var ei=0;ei<140;ei++){var ea=ei/140*6.28,er=5+Math.random()*.9;eqPos[ei*3]=Math.cos(ea)*er;eqPos[ei*3+1]=(Math.random()-.5)*.5;eqPos[ei*3+2]=Math.sin(ea)*er;}
          eqG.setAttribute('position',new THREE.BufferAttribute(eqPos,3));
          var eqPts=new THREE.Points(eqG,new THREE.PointsMaterial({color:0x4ecdc4,size:.055,transparent:true,opacity:.52,sizeAttenuation:true}));
          scene.add(eqPts);

          var scmx=0,scmy=0,tscmx=0,tscmy=0;
          document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();tscmx=(e.clientX-rc.left-rc.width/2)/(rc.width/2);tscmy=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          window.addEventListener('resize',function(){var ns=sz();renderer.setSize(ns.w,ns.h);camera.aspect=ns.w/ns.h;camera.updateProjectionMatrix();});

          var clk=new THREE.Clock();
          function anim(){
            requestAnimationFrame(anim);var t=clk.getElapsedTime();
            scmx+=(tscmx-scmx)*.06;scmy+=(tscmy-scmy)*.06;
            cA.rotation.x+=.0025;cA.rotation.y+=.004;cA.rotation.z+=.001;
            cB.rotation.x-=.006;cB.rotation.y-=.0045;cB.rotation.z+=.0035;
            cC.rotation.x+=.011;cC.rotation.y+=.008;cC.rotation.z-=.006;
            cD.rotation.x-=.016;cD.rotation.y+=.013;cD.rotation.z+=.009;
            orbs.forEach(function(o){o.m.rotation.x+=.005;o.m.rotation.y+=.008;var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.5,Math.sin(a)*o.r*.7);});
            sRings.forEach(function(r,i){r.m.rotation.z+=r.rs*(i%2===0?1:-1);r.m.rotation.y+=r.rs*.65;r.m.rotation.x+=r.rs*.3;});
            sOctas.forEach(function(o){var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.4,Math.sin(a)*o.r*.6);o.m.rotation.x+=.01;o.m.rotation.y+=.012;});
            spPts.rotation.y=t*.02;spPts.rotation.x=t*.01;cPts.rotation.y=-t*.016;purPts.rotation.y=t*.018;purPts.rotation.x=t*.009;eqPts.rotation.y=-t*.014;
            camera.position.x=scmx*2.4;camera.position.y=scmy*1.8;camera.lookAt(scmx*.3,scmy*.2,0);
            sp1.position.set(4+Math.sin(t*.5)*2.5,4+Math.cos(t*.38)*2,5);sp2.position.set(-4+Math.cos(t*.42)*2,-3+Math.sin(t*.3)*2,4);sp3.position.set(Math.sin(t*.26)*3,6+Math.cos(t*.2)*2,3);
            sl1.intensity=16+Math.sin(t*.3)*5;sl2.intensity=10+Math.sin(t*.24+1)*3;
            renderer.render(scene,camera);
          }
          anim();
        }

        // Start — if THREE already loaded synchronously, go; else wait
        if(typeof THREE!=='undefined'){initThree();}
        else{window._pendingInit=initThree;setTimeout(function(){if(typeof THREE!=='undefined')initThree();},2500);}

        })();
    </script>
</body>
</html>
