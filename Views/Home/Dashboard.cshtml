          scene.add(globe);scene.add(globeW);

          /* Grid lines */
          var gg=new THREE.Group();
          for(var lat=0;lat<10;lat++){var ry=Math.PI/9*lat-Math.PI/2;var rn=new THREE.TorusGeometry(2.65*Math.cos(ry),.003,2,80);var rm=new THREE.Mesh(rn,mBB(0xc9a96e,.12));rm.rotation.x=Math.PI/2;rm.position.y=2.65*Math.sin(ry);gg.add(rm);}
          for(var lon=0;lon<16;lon++){var ln=new THREE.TorusGeometry(2.65,.003,2,80);var lm=new THREE.Mesh(ln,mBB(0xc9a96e,.08));lm.rotation.y=Math.PI/8*lon;gg.add(lm);}
          scene.add(gg);

          /* Orbiting cubes */
          var orbs=[];
          for(var oi=0;oi<18;oi++){var sz=.22+Math.random()*.65;var g2=new THREE.BoxGeometry(sz,sz,sz,1,1,1);var om=new THREE.Mesh(g2,mPP(oi%3===0?0xc9a96e:oi%3===1?0x4ecdc4:0x8b5cf6,.11,.05));om.add(new THREE.LineSegments(new THREE.EdgesGeometry(g2),eL(oi%3===0?0xc9a96e:oi%3===1?0x4ecdc4:0x8b5cf6,.58)));scene.add(om);orbs.push({m:om,r:3.2+Math.random()*4.5,sp:.22+Math.random()*.52,ph:oi*.349,ti:.3+Math.random()*.55});}

          /* Rings */
          var rings=[];
          [{r:3.6,tb:.007,c:0xc9a96e,op:.32,rx:1.05,rz:0,rs:.005},{r:5,tb:.005,c:0x4ecdc4,op:.22,rx:.78,rz:.78,rs:.004},{r:6.5,tb:.003,c:0xc9a96e,op:.13,rx:.62,rz:.62,rs:.003},{r:4.2,tb:.008,c:0x4ecdc4,op:.2,rx:1.57,rz:.52,rs:.007},{r:8,tb:.002,c:0xd4b87e,op:.08,rx:.52,rz:1.05,rs:.0018},{r:4.8,tb:.006,c:0x8b5cf6,op:.17,rx:.4,rz:.6,rs:.005},{r:7,tb:.003,c:0x8b5cf6,op:.11,rx:.7,rz:.78,rs:.0032}].forEach(function(d){var g=new THREE.TorusGeometry(d.r,d.tb,2,100),m=new THREE.Mesh(g,mBB(d.c,d.op));m.rotation.x=d.rx;m.rotation.z=d.rz;scene.add(m);rings.push({m:m,rs:d.rs});});

          /* Threat pings */
          var pings=[];
          for(var pi=0;pi<24;pi++){var phi=Math.acos(2*Math.random()-1),theta=Math.random()*Math.PI*2,rr=2.8;var pd=new THREE.Mesh(new THREE.SphereGeometry(.06,5,5),new THREE.MeshBasicMaterial({color:pi%4===0?0xff4466:pi%4===1?0xc9a96e:pi%4===2?0x22c55e:0x4ecdc4,transparent:true,opacity:.85}));pd.position.set(rr*Math.sin(phi)*Math.cos(theta),rr*Math.cos(phi),rr*Math.sin(phi)*Math.sin(theta));scene.add(pd);pings.push({m:pd,fp:Math.random()*6.28,fs:.3+Math.random()*.7});}

          /* Icosa shells */
          [[3.8,.055,0xc9a96e],[5.2,.034,0x4ecdc4],[7,.02,0x8b5cf6]].forEach(function(d){scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.IcosahedronGeometry(d[0],1)),eL(d[2],d[1])));});

          /* Particles */
          function mkSP2(n,mn,mx2,col,sz,op){var g=new THREE.BufferGeometry(),pos=new Float32Array(n*3);for(var ii=0;ii<n;ii++){var r=mn+Math.random()*(mx2-mn),th=Math.random()*6.28,ph=Math.acos(2*Math.random()-1);pos[ii*3]=r*Math.sin(ph)*Math.cos(th);pos[ii*3+1]=r*Math.sin(ph)*Math.sin(th);pos[ii*3+2]=r*Math.cos(ph);}g.setAttribute('position',new THREE.BufferAttribute(pos,3));return new THREE.Points(g,new THREE.PointsMaterial({color:col,size:sz,transparent:true,opacity:op,sizeAttenuation:true}));}
          var sp1=mkSP2(700,2.8,8.5,0xc9a96e,.038,.5),sp2=mkSP2(220,4.5,7,0x4ecdc4,.048,.38),sp3=mkSP2(140,3.5,6,0x8b5cf6,.042,.3);
          scene.add(sp1);scene.add(sp2);scene.add(sp3);

          var hmx2=0,hmy2=0,thmx2=0,thmy2=0;
          document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();thmx2=(e.clientX-rc.left-rc.width/2)/(rc.width/2);thmy2=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          autoResize(renderer,camera,W,H);
          var clk=new THREE.Clock();

          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            hmx2+=(thmx2-hmx2)*.055;hmy2+=(thmy2-hmy2)*.055;
            gg.rotation.y=t*.1;globe.rotation.y=t*.1;globeW.rotation.y=t*.1;
            orbs.forEach(function(o){o.m.rotation.x+=.007;o.m.rotation.y+=.01;var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.42,Math.sin(a)*o.r*.68);});
            rings.forEach(function(r,i){r.m.rotation.z+=r.rs*(i%2===0?1:-1);r.m.rotation.y+=r.rs*.55;r.m.rotation.x+=r.rs*.22;});
            pings.forEach(function(p){var s=.6+Math.sin(t*p.fs+p.fp)*.4;p.m.scale.setScalar(s);p.m.material.opacity=.45+Math.sin(t*p.fs+p.fp)*.42;});
            sp1.rotation.y=t*.018;sp1.rotation.x=t*.009;sp2.rotation.y=-t*.014;sp3.rotation.y=t*.016;
            camera.position.x=hmx2*1.8;camera.position.y=hmy2*1.4;camera.lookAt(hmx2*.22,hmy2*.18,0);
            p1.position.set(4+Math.sin(t*.45)*2.5,4+Math.cos(t*.35)*2,6);p2.position.set(-4+Math.cos(t*.38)*2,-3+Math.sin(t*.28)*2,5);
            renderer.render(scene,camera);})();
        })();

        /* ══════════════════════════════
           5-8. MINI WIDGET SCENES
        ══════════════════════════════ */
        function makeMini(id, accent1, accent2, style){
          var canvas=document.getElementById(id);if(!canvas)return;
          var wrap=canvas.parentElement;
          var W=function(){return wrap.offsetWidth;},H=function(){return wrap.offsetHeight;};
          var renderer=mkRenderer(canvas);renderer.setSize(W(),H());
          var scene=new THREE.Scene();
          var camera=new THREE.PerspectiveCamera(50,W()/H(),.1,50);camera.position.set(0,0,6);

          scene.add(new THREE.AmbientLight(0x04040a,2));
          var kL=new THREE.SpotLight(0xc9a96e,18,28,Math.PI/4,.3,1.4);kL.position.set(5,8,7);scene.add(kL);
          var fL=new THREE.SpotLight(accent1,12,20,Math.PI/3,.4,1.6);fL.position.set(-5,3,5);scene.add(fL);
          var p1=new THREE.PointLight(accent1,6,14);scene.add(p1);

          var objects=[];

          if(style==='nested'){
            /* Nested rotating cubes + rings */
            [[2.4,.07,.04,0xc9a96e],[1.5,.09,.05,accent1],[.85,.11,.04,accent2],[.42,.14,.03,0xc9a96e]].forEach(function(d,i){
              var g=new THREE.BoxGeometry(d[0],d[0],d[0],2,2,2);
              var m=new THREE.Mesh(g,mPP(d[3],d[1],d[2]));
              m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eL(d[3],i===0?.6:.7)));
              scene.add(m);objects.push({m:m,rx:(.004+i*.002)*(i%2===0?1:-1),ry:.005+i*.003,rz:.002+i*.001,type:'cube'});
            });
            /* Orbiting mini cubes */
            for(var oi=0;oi<10;oi++){var sz=.18+Math.random()*.4;var g2=new THREE.BoxGeometry(sz,sz,sz,1,1,1);var om=new THREE.LineSegments(new THREE.EdgesGeometry(g2),eL(oi%2===0?accent1:accent2,.5));scene.add(om);objects.push({m:om,r:2+Math.random()*2.2,sp:.35+Math.random()*.55,ph:oi*.628,ti:.4+Math.random()*.45,type:'orb'});}
            /* Rings */
            [[2.8,.006,0xc9a96e,.28,1.05,0,.005],[3.6,.004,accent1,.18,.78,.78,.004],[4.2,.003,accent2,.12,.62,.62,.003]].forEach(function(d){var g=new THREE.TorusGeometry(d[0],d[1],2,80),m=new THREE.Mesh(g,mBB(d[2],d[3]));m.rotation.x=d[4];m.rotation.z=d[5];scene.add(m);objects.push({m:m,rs:d[6],type:'ring'});});

          } else if(style==='orbs'){
            /* Central icosa with many orbiters */
            var ig=new THREE.IcosahedronGeometry(1.4,2);
            var im=new THREE.Mesh(ig,mPP(accent1,.1,.06));
            im.add(new THREE.LineSegments(new THREE.EdgesGeometry(ig),eL(accent1,.4)));
            scene.add(im);objects.push({m:im,rx:.007,ry:.009,rz:.005,type:'cube'});
            for(var oi2=0;oi2<12;oi2++){var sz2=.15+Math.random()*.45;var gg2=new THREE.BoxGeometry(sz2,sz2,sz2,1,1,1);var om2=new THREE.LineSegments(new THREE.EdgesGeometry(gg2),eL(oi2%3===0?0xc9a96e:oi2%3===1?accent1:accent2,.52));scene.add(om2);objects.push({m:om2,r:1.8+Math.random()*2.5,sp:.3+Math.random()*.6,ph:oi2*.523,ti:.35+Math.random()*.5,type:'orb'});}
            [[2.4,.007,accent1,.3,1.05,0,.006],[3.2,.004,accent2,.18,.78,.78,.004],[4,.003,0xc9a96e,.12,.5,.5,.003]].forEach(function(d){var g=new THREE.TorusGeometry(d[0],d[1],2,80),m=new THREE.Mesh(g,mBB(d[2],d[3]));m.rotation.x=d[4];m.rotation.z=d[5];scene.add(m);objects.push({m:m,rs:d[6],type:'ring'});});

          } else {
            /* Scatter of various wireframe forms */
            for(var i2=0;i2<18;i2++){
              var t2=i2%3;var sz3=.2+Math.random()*.5;var g3;
              if(t2===0)g3=new THREE.BoxGeometry(sz3,sz3,sz3,1,1,1);
              else if(t2===1)g3=new THREE.OctahedronGeometry(sz3*.7,0);
              else g3=new THREE.IcosahedronGeometry(sz3*.6,0);
              var m3=new THREE.LineSegments(new THREE.EdgesGeometry(g3),eL(i2%3===0?0xc9a96e:i2%3===1?accent1:accent2,.12+Math.random()*.18));
              m3.position.set((Math.random()-.5)*4.5,(Math.random()-.5)*3.5,-Math.random()*3);m3.rotation.set(Math.random()*6.28,Math.random()*6.28,Math.random()*6.28);
              scene.add(m3);objects.push({m:m3,rs:{x:(Math.random()-.5)*.012,y:(Math.random()-.5)*.013,z:(Math.random()-.5)*.008},oy:m3.position.y,fp:Math.random()*6.28,fs:.18+Math.random()*.28,type:'scatter'});
            }
          }

          autoResize(renderer,camera,W,H);
          var clk=new THREE.Clock();
          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            objects.forEach(function(o){
              if(o.type==='cube'){o.m.rotation.x+=o.rx;o.m.rotation.y+=o.ry;o.m.rotation.z+=o.rz;}
              else if(o.type==='orb'){var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.38,Math.sin(a)*o.r*.6);o.m.rotation.x+=.009;o.m.rotation.y+=.012;}
              else if(o.type==='ring'){o.m.rotation.z+=o.rs;o.m.rotation.y+=o.rs*.6;o.m.rotation.x+=o.rs*.22;}
              else{o.m.rotation.x+=o.rs.x;o.m.rotation.y+=o.rs.y;o.m.rotation.z+=o.rs.z;o.m.position.y=o.oy+Math.sin(t*o.fs+o.fp)*.2;}
            });
            p1.position.set(Math.sin(t*.45)*3,Math.cos(t*.38)*3,4.5);
            renderer.render(scene,camera);})();
        }

        makeMini('MINI_A', 0xc9a96e, 0x4ecdc4, 'nested');
        makeMini('MINI_B', 0xff4466, 0x8b5cf6, 'orbs');
        makeMini('MINI_C', 0x4ecdc4, 0xc9a96e, 'scatter');
        makeMini('MINI_D', 0x8b5cf6, 0xd4b87e, 'nested');

        /* ══════════════════════════════
           9. THREAT CORE (big bottom right)
        ══════════════════════════════ */
        (function(){
          var canvas=document.getElementById('CORE3D');
          var wrap=canvas.parentElement;
          var W=function(){return wrap.offsetWidth;},H=function(){return wrap.offsetHeight;};
          var renderer=mkRenderer(canvas);renderer.setSize(W(),H());
          var scene=new THREE.Scene();
          var camera=new THREE.PerspectiveCamera(48,W()/H(),.1,80);camera.position.set(0,0,8);

          scene.add(new THREE.AmbientLight(0x04040e,2));
          var kL=new THREE.SpotLight(0xc9a96e,22,38,Math.PI/5,.3,1.2);kL.position.set(8,12,10);scene.add(kL);
          var fL=new THREE.SpotLight(0xff4466,18,30,Math.PI/4,.35,1.5);fL.position.set(-8,5,8);scene.add(fL);
          var bL=new THREE.SpotLight(0x8b5cf6,10,22,Math.PI/3,.5,1.8);bL.position.set(-4,-9,7);scene.add(bL);
          var p1=new THREE.PointLight(0xff4466,9,20);scene.add(p1);var p2=new THREE.PointLight(0xc9a96e,7,18);scene.add(p2);

          /* Central threat cube mega-structure */
          var coreObjs=[];
          [[4.5,.06,.04,0xc9a96e],[3,.08,.05,0xff4466],[1.8,.1,.04,0x8b5cf6],[1,.13,.03,0x4ecdc4],[.5,.16,.04,0xc9a96e]].forEach(function(d,i){
            var g=new THREE.BoxGeometry(d[0],d[0],d[0],3,3,3);
            var m=new THREE.Mesh(g,mPP(d[2]===.04&&i===0?0xc9a96e:d[2]===.04&&i===2?0x8b5cf6:d[3],d[1],d[2]));
            m.add(new THREE.LineSegments(new THREE.EdgesGeometry(g),eL(d[3],i===0?.45:.65)));
            scene.add(m);coreObjs.push({m:m,rx:(.003+i*.0025)*(i%2===0?1:-1),ry:.004+i*.003,rz:.002+i*.0015,type:'core'});
          });

          /* Many orbiting cubes at various distances */
          for(var oi=0;oi<22;oi++){
            var sz=.18+Math.random()*.62;
            var g2=new THREE.BoxGeometry(sz,sz,sz,2,2,2);
            var col=oi%4===0?0xc9a96e:oi%4===1?0xff4466:oi%4===2?0x4ecdc4:0x8b5cf6;
            var om=new THREE.Mesh(g2,mPP(col,.1,.05));
            om.add(new THREE.LineSegments(new THREE.EdgesGeometry(g2),eL(col,.6)));
            scene.add(om);coreObjs.push({m:om,r:2.8+Math.random()*5,sp:.2+Math.random()*.55,ph:oi*.285,ti:.3+Math.random()*.6,type:'orb'});
          }

          /* Outer rings — many */
          [{r:3.2,tb:.007,c:0xc9a96e,op:.28,rx:1.05,rz:0,rs:.006},{r:4.5,tb:.005,c:0xff4466,op:.22,rx:.78,rz:.78,rs:.005},{r:5.8,tb:.004,c:0xc9a96e,op:.15,rx:.62,rz:.62,rs:.004},{r:3.8,tb:.008,c:0x4ecdc4,op:.2,rx:1.57,rz:.52,rs:.007},{r:7,tb:.003,c:0xd4b87e,op:.1,rx:.52,rz:1.05,rs:.002},{r:4.8,tb:.006,c:0x8b5cf6,op:.18,rx:.4,rz:.6,rs:.005},{r:6.5,tb:.003,c:0x8b5cf6,op:.12,rx:.7,rz:.78,rs:.0035},{r:2.8,tb:.009,c:0xff4466,op:.25,rx:.3,rz:1.2,rs:.006},{r:8.5,tb:.002,c:0xc9a96e,op:.07,rx:.15,rz:.5,rs:.0016}].forEach(function(d){
            var g=new THREE.TorusGeometry(d.r,d.tb,2,100),m=new THREE.Mesh(g,mBB(d.c,d.op));
            m.rotation.x=d.rx;m.rotation.z=d.rz;scene.add(m);coreObjs.push({m:m,rs:d.rs,type:'ring'});
          });

          /* Icosa shells */
          [[2.4,.06,0xc9a96e],[3.6,.04,0xff4466],[5,.025,0x8b5cf6],[6.5,.016,0x4ecdc4]].forEach(function(d){scene.add(new THREE.LineSegments(new THREE.EdgesGeometry(new THREE.IcosahedronGeometry(d[0],1)),eL(d[2],d[1])));});

          /* Threat pings — red dominant */
          var tpings=[];
          for(var pi=0;pi<18;pi++){var phi=Math.acos(2*Math.random()-1),theta=Math.random()*Math.PI*2,rr=2.5+Math.random()*.5;var pd=new THREE.Mesh(new THREE.SphereGeometry(.07,5,5),new THREE.MeshBasicMaterial({color:pi%3===0?0xff4466:pi%3===1?0xc9a96e:0x22c55e,transparent:true,opacity:.9}));pd.position.set(rr*Math.sin(phi)*Math.cos(theta),rr*Math.cos(phi),rr*Math.sin(phi)*Math.sin(theta));scene.add(pd);tpings.push({m:pd,fp:Math.random()*6.28,fs:.3+Math.random()*.7});}

          /* Particles */
          var spg=new THREE.BufferGeometry(),spPos=new Float32Array(800*3);
          for(var si=0;si<800;si++){var sr=2+Math.random()*8,st=Math.random()*6.28,sphi=Math.acos(2*Math.random()-1);spPos[si*3]=sr*Math.sin(sphi)*Math.cos(st);spPos[si*3+1]=sr*Math.sin(sphi)*Math.sin(st);spPos[si*3+2]=sr*Math.cos(sphi);}
          spg.setAttribute('position',new THREE.BufferAttribute(spPos,3));
          var spPts=new THREE.Points(spg,new THREE.PointsMaterial({color:0xc9a96e,size:.038,transparent:true,opacity:.45,sizeAttenuation:true}));scene.add(spPts);
          var rspg=new THREE.BufferGeometry(),rspPos=new Float32Array(300*3);
          for(var si2=0;si2<300;si2++){var sr2=3+Math.random()*5,st2=Math.random()*6.28,sphi2=Math.acos(2*Math.random()-1);rspPos[si2*3]=sr2*Math.sin(sphi2)*Math.cos(st2);rspPos[si2*3+1]=sr2*Math.sin(sphi2)*Math.sin(st2);rspPos[si2*3+2]=sr2*Math.cos(sphi2);}
          rspg.setAttribute('position',new THREE.BufferAttribute(rspPos,3));
          var rPts=new THREE.Points(rspg,new THREE.PointsMaterial({color:0xff4466,size:.042,transparent:true,opacity:.35,sizeAttenuation:true}));scene.add(rPts);

          var hmx3=0,hmy3=0,thmx3=0,thmy3=0;
          document.addEventListener('mousemove',function(e){var rc=canvas.getBoundingClientRect();thmx3=(e.clientX-rc.left-rc.width/2)/(rc.width/2);thmy3=-(e.clientY-rc.top-rc.height/2)/(rc.height/2);});
          autoResize(renderer,camera,W,H);
          var clk=new THREE.Clock();

          (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
            hmx3+=(thmx3-hmx3)*.055;hmy3+=(thmy3-hmy3)*.055;
            coreObjs.forEach(function(o){
              if(o.type==='core'){o.m.rotation.x+=o.rx;o.m.rotation.y+=o.ry;o.m.rotation.z+=o.rz;}
              else if(o.type==='orb'){var a=t*o.sp+o.ph;o.m.position.set(Math.cos(a)*o.r,Math.sin(a*o.ti)*o.r*.42,Math.sin(a)*o.r*.68);o.m.rotation.x+=.007;o.m.rotation.y+=.01;}
              else if(o.type==='ring'){o.m.rotation.z+=o.rs*(coreObjs.indexOf(o)%2===0?1:-1);o.m.rotation.y+=o.rs*.6;o.m.rotation.x+=o.rs*.22;}
            });
            tpings.forEach(function(p){var s=.6+Math.sin(t*p.fs+p.fp)*.42;p.m.scale.setScalar(s);p.m.material.opacity=.45+Math.sin(t*p.fs+p.fp)*.44;});
            spPts.rotation.y=t*.014;spPts.rotation.x=t*.007;rPts.rotation.y=-t*.011;rPts.rotation.z=t*.008;
            camera.position.x=hmx3*2;camera.position.y=hmy3*1.6;camera.lookAt(hmx3*.25,hmy3*.2,0);
            p1.position.set(4+Math.sin(t*.45)*2.5,4+Math.cos(t*.35)*2,6);p2.position.set(-4+Math.cos(t*.38)*2,-3+Math.sin(t*.28)*2,5);
            kL.intensity=22+Math.sin(t*.28)*7;fL.intensity=18+Math.sin(t*.22+1)*5;
            renderer.render(scene,camera);})();
        })();

        })(); // end IIFE
    </script>
</body>
</html>
