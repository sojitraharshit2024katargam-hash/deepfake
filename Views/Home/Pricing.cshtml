    var cg2=new THREE.OctahedronGeometry(.7,0);var cM2=new THREE.Mesh(cg2,mPP(col,.8,.03));cM2.add(new THREE.LineSegments(new THREE.EdgesGeometry(cg2),eL(col,.9)));group.add(cM2);group.userData.gem=cM2;
