    cm.position.set(ox,oy,oz);cm.rotation.x=Math.random()*Math.PI*.5+Math.PI*.2;cm.rotation.z=Math.random()*6.28;
    scene.add(cm);coins.push({m:cm,ox:ox,oz:oz,speed:.025+Math.random()*.06,tilt:Math.random()*.02});
  }

  /* Large faint coin ring halos */
  for(var i=0;i<5;i++){
    var r2=6+i*5,cg2=new THREE.TorusGeometry(r2,.03,2,80);
    var m2=new THREE.Mesh(cg2,mBB(0xc9a96e,.05+i*.01));
    m2.rotation.x=Math.PI*.5+i*.15;m2.rotation.y=i*.3;scene.add(m2);
  }

  /* Particles — gold dust */
  var pP=new Float32Array(2000*3);
  for(var i=0;i<2000;i++){pP[i*3]=(Math.random()-.5)*70;pP[i*3+1]=-30+Math.random()*60;pP[i*3+2]=-4-Math.random()*24;}
  var pG=new THREE.BufferGeometry();pG.setAttribute('position',new THREE.BufferAttribute(pP,3));
  var pPts=new THREE.Points(pG,new THREE.PointsMaterial({color:0xc9a96e,size:.04,transparent:true,opacity:.28,sizeAttenuation:true}));scene.add(pPts);

  var cmx=0,cmy=0,tmx=0,tmy=0,sY=0;
  document.addEventListener('mousemove',function(e){tmx=(e.clientX/W()-.5)*2;tmy=-(e.clientY/H()-.5)*2;});
  window.addEventListener('scroll',function(){sY=window.scrollY;},{passive:true});
  window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
  var clk=new THREE.Clock();
  (function tick(){requestAnimationFrame(tick);var t=clk.getElapsedTime();
    cmx+=(tmx-cmx)*.015;cmy+=(tmy-cmy)*.015;
    var sP=Math.min(1,sY/Math.max(1,document.body.scrollHeight-H()));
    /* Coins rise upward */
    coins.forEach(function(c){
      c.m.position.y+=c.speed;c.m.rotation.y+=c.tilt*.3;c.m.rotation.z+=c.tilt;
      if(c.m.position.y>30)c.m.position.y=-28+Math.random()*4;
    });
    /* Particle drift */
    var pp=pG.attributes.position.array;
    for(var i=0;i<2000;i++){pp[i*3+1]+=.012;if(pp[i*3+1]>30)pp[i*3+1]=-30;}
    pG.attributes.position.needsUpdate=true;
    camera.position.x=lerp(camera.position.x,cmx*3.5,.05);
    camera.position.y=lerp(camera.position.y,cmy*2.5+sP*-6,.05);
    p1.position.set(10+Math.sin(t*.35)*5,10+Math.cos(t*.27)*3.5,10);
    p2.position.set(-9+Math.cos(t*.3)*3,-7+Math.sin(t*.24)*2.5,8);
    renderer.render(scene,camera);
  })();
})();

/* ══════════════════════════════════════
   HERO 3D: PRICING PYRAMID / VALUE VAULT
   Three ascending crystal towers (tiers)
   with coin rings orbiting each
══════════════════════════════════════ */
(function(){
  var canvas=document.getElementById('HERO3D');
  var wrap=canvas.parentElement;
  var W=function(){return wrap.offsetWidth;},H=function(){return wrap.offsetHeight;};
  var renderer=mkR(canvas);renderer.setSize(W(),H());
  var scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x04040a,.026);
  var camera=new THREE.PerspectiveCamera(54,W()/H(),.1,100);camera.position.set(0,2,16);
  scene.add(new THREE.AmbientLight(0x04040e,1.8));
  var kL=new THREE.SpotLight(0xc9a96e,26,55,Math.PI/4,.28,1.2);kL.position.set(14,20,18);scene.add(kL);
  var fL=new THREE.SpotLight(0x4ecdc4,16,42,Math.PI/3,.32,1.5);fL.position.set(-12,8,14);scene.add(fL);
  var eL2=new THREE.SpotLight(0x8b5cf6,20,48,Math.PI/4,.3,1.4);eL2.position.set(8,-10,12);scene.add(eL2);
  var p1=new THREE.PointLight(0xc9a96e,9,22);scene.add(p1);var p2=new THREE.PointLight(0x8b5cf6,6,18);scene.add(p2);

  var group=new THREE.Group();scene.add(group);

  /* THREE TIER CRYSTAL TOWERS */
  var tiers=[
    {x:-5.5,h:3,r:.9,col:0x4ecdc4,name:'Free'},
    {x:0,h:5.5,r:1.1,col:0xc9a96e,name:'Pro'},
    {x:5.5,h:7.8,r:1.3,col:0x8b5cf6,name:'Ent'}
  ];
  var towers=[];
  tiers.forEach(function(td){
    var tg=new THREE.Group();group.add(tg);tg.position.x=td.x;
    /* Stack of coin discs = tier height */
    var stackCount=Math.round(td.h*3);
    for(var si=0;si<stackCount;si++){
      var cg=new THREE.CylinderGeometry(td.r*.9,td.r,.22,18,1);
      var cm=new THREE.Mesh(cg,mPP(td.col,.45,.04));
      cm.add(new THREE.LineSegments(new THREE.EdgesGeometry(cg),eL(td.col,.5)));
      cm.position.y=si*.26-td.h/2;tg.add(cm);
    }
    /* Capstone gem */
    var gem=new THREE.OctahedronGeometry(td.r*.62,0);
    var gemM=new THREE.Mesh(gem,mPP(td.col,.7,.03));
    gemM.add(new THREE.LineSegments(new THREE.EdgesGeometry(gem),eL(td.col,.8)));
    gemM.position.y=td.h/2+.5;tg.add(gemM);
    /* Orbiting ring */
    var rg=new THREE.TorusGeometry(td.r*1.9,.01,2,70);
    var rm=new THREE.Mesh(rg,mBB(td.col,.32));
    rm.rotation.x=Math.PI*.25;tg.add(rm);
    /* Label plane — just color marker */
    towers.push({g:tg,gemM:gemM,rm:rm,col:td.col,x:td.x,rotY:0});
  });

  /* Base platform */
  var platG=new THREE.CylinderGeometry(9,.5,.12,8,1);
  var platM=new THREE.Mesh(platG,mPP(0xc9a96e,.06,.06));
  platM.add(new THREE.LineSegments(new THREE.EdgesGeometry(platG),eL(0xc9a96e,.14)));
  platM.position.y=-3.8;group.add(platM);

  /* Coin ring around whole scene */
  [[5,.007,0xc9a96e,.2,Math.PI/2,0,.006],[7,.005,0x8b5cf6,.14,1.05,.78,.005],[9,.003,0x4ecdc4,.09,.52,1.05,.003]].forEach(function(d){
    var rg=new THREE.TorusGeometry(d[0],d[1],2,100);var rm=new THREE.Mesh(rg,mBB(d[2],d[3]));
    rm.rotation.x=d[4];rm.rotation.z=d[5];group.add(rm);towers.push({rm:rm,rs:d[6],type:'ring'});
  });

  /* Ambient coin particles */
  var pP=new Float32Array(600*3);var ph=new Float32Array(600);
  for(var i=0;i<600;i++){var r=3.5+Math.random()*6.5,th=Math.random()*6.28,phi=Math.acos(2*Math.random()-1);pP[i*3]=r*Math.sin(phi)*Math.cos(th);pP[i*3+1]=r*Math.sin(phi)*Math.sin(th);pP[i*3+2]=r*Math.cos(phi);ph[i]=Math.random()*6.28;}
  var pG=new THREE.BufferGeometry();pG.setAttribute('position',new THREE.BufferAttribute(pP,3));
  group.add(new THREE.Points(pG,new THREE.PointsMaterial({color:0xc9a96e,size:.05,transparent:true,opacity:.42,sizeAttenuation:true})));

  var hmx=0,hmy=0,tmx=0,tmy=0;
