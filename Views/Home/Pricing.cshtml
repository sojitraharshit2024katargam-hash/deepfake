    var shieldPts=[new THREE.Vector3(0,2.2,0),new THREE.Vector3(1.8,.8,0),new THREE.Vector3(1.8,-1.2,0),new THREE.Vector3(0,-2.5,0),new THREE.Vector3(-1.8,-1.2,0),new THREE.Vector3(-1.8,.8,0)];
