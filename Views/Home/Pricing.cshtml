  var clk=new THREE.Clock();
  (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
    hmx+=(tmx-hmx)*.055;hmy+=(tmy-hmy)*.055;
    towers.forEach(function(tw){
      if(tw.type==='ring'){tw.rm.rotation.z+=tw.rs;tw.rm.rotation.y+=tw.rs*.6;return;}
      if(tw.gemM){tw.gemM.rotation.y=t*.6;tw.gemM.position.y=tw.g.children[tw.g.children.length-2].position.y+.5+Math.sin(t*.8+tw.x)*.18;}
