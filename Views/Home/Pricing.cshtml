══════════════════════════════════════ */
(function(){
  var canvas=document.getElementById('BG');
  var W=function(){return window.innerWidth;},H=function(){return window.innerHeight;};
  var renderer=mkR(canvas);renderer.setSize(W(),H());
  canvas.style.cssText='position:fixed;inset:0;z-index:0;pointer-events:none;width:100%;height:100%';
  var scene=new THREE.Scene();scene.fog=new THREE.FogExp2(0x04040a,.016);
  var camera=new THREE.PerspectiveCamera(58,W()/H(),.1,500);camera.position.set(0,0,24);
  scene.add(new THREE.AmbientLight(0x04040e,2.5));
  var kL=new THREE.SpotLight(0xc9a96e,22,90,Math.PI/6,.3,1.2);kL.position.set(20,24,18);scene.add(kL);
  var fL=new THREE.SpotLight(0x8b5cf6,12,65,Math.PI/5,.4,1.5);fL.position.set(-18,10,14);scene.add(fL);
  var p1=new THREE.PointLight(0xc9a96e,7,45);scene.add(p1);var p2=new THREE.PointLight(0x4ecdc4,4,32);scene.add(p2);

  /* COIN geometry — thin cylinders */
  var coins=[];
  for(var i=0;i<55;i++){
    var r=0.4+Math.random()*.9;
    var cg=new THREE.CylinderGeometry(r,r,.06+Math.random()*.06,24,1);
    var col=i%4===0?0xc9a96e:i%4===1?0xd4b87e:i%4===2?0xf0c060:0xb8943e;
    var cm=new THREE.Mesh(cg,mPP(col,.55,.05));
