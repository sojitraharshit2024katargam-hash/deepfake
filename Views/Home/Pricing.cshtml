/* TOAST */
.tw{position:fixed;right:18px;bottom:18px;z-index:3000;display:grid;gap:7px;width:min(320px,calc(100vw - 36px))}
.toastx{border:1px solid var(--s);background:rgba(4,4,10,.97);backdrop-filter:blur(24px);padding:12px 14px;display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;position:relative;overflow:hidden;animation:TI .35s var(--ease)}
.toastx::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--g),transparent)}
@@keyframes TI{from{transform:translateX(8px);opacity:0}to{transform:translateX(0);opacity:1}}
.t-ic{width:28px;height:28px;border:1px solid var(--g3);display:grid;place-items:center;font-size:10px}
.t-h{font-size:11px;font-weight:700}.t-p{font-family:'DM Mono',monospace;font-size:8px;color:var(--c3);margin-top:1px}
.t-x{background:none;border:none;cursor:none;color:var(--c4);font-size:11px;padding:3px;transition:color .2s}

::selection{background:rgba(201,169,110,.18);color:var(--c)}
