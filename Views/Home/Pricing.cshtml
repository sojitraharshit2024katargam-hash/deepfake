  var scene=new THREE.Scene();
  var camera=new THREE.PerspectiveCamera(48,W()/H(),.1,40);camera.position.set(0,0,6.5);
  scene.add(new THREE.AmbientLight(0x04040a,2));
  var col=tier==='free'?0x4ecdc4:tier==='pro'?0xc9a96e:0x8b5cf6;
  var col2=tier==='free'?0xd4b87e:tier==='pro'?0xf0c060:0xd4b87e;
  var kL=new THREE.SpotLight(col,18,22,Math.PI/3,.28,1.4);kL.position.set(5,8,8);scene.add(kL);
  var fL=new THREE.SpotLight(col2,12,16,Math.PI/3,.35,1.6);fL.position.set(-4,3,6);scene.add(fL);
  var p1=new THREE.PointLight(col,7,14);scene.add(p1);

  var group=new THREE.Group();scene.add(group);

  if(tier==='free'){
    /* SEED CRYSTAL: Small gem growing from base */
    var octG=new THREE.OctahedronGeometry(1,0);
    var octM=new THREE.Mesh(octG,mPP(col,.65,.04));
    octM.add(new THREE.LineSegments(new THREE.EdgesGeometry(octG),eL(col,.7)));
    group.add(octM);
    /* Small coin base */
    var baseG=new THREE.CylinderGeometry(1.3,1.5,.2,18,1);
    var baseM=new THREE.Mesh(baseG,mPP(col,.25,.06));
    baseM.position.y=-1.3;group.add(baseM);
