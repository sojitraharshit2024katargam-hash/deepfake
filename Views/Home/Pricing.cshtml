    for(var i=0;i<12;i++){var og=new THREE.OctahedronGeometry(.1,0);var om=new THREE.Mesh(og,mBB(i%3===0?col:i%3===1?col2:0xc9a96e,.8));group.add(om);group.userData.orbits=group.userData.orbits||[];group.userData.orbits.push({m:om,r:1.6+Math.random()*.8,sp:.4+Math.random()*.5,ph:i*.524,ti:.5+Math.random()*.5});}
  }

  window.addEventListener('resize',function(){renderer.setSize(W(),H());camera.aspect=W()/H();camera.updateProjectionMatrix();});
  var clk=new THREE.Clock();
  (function anim(){requestAnimationFrame(anim);var t=clk.getElapsedTime();
