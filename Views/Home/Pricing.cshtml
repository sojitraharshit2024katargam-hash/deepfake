    [[2.5,.006,col,.28,Math.PI/2,0],[3.2,.005,col2,.2,1.05,.78],[3.8,.004,col,.15,.52,1.05]].forEach(function(d){
      var rg=new THREE.TorusGeometry(d[0],d[1],2,90);var rm=new THREE.Mesh(rg,mBB(d[2],d[3]));
      rm.rotation.x=d[4];rm.rotation.z=d[5];group.add(rm);group.userData.rings=group.userData.rings||[];group.userData.rings.push(rm);
    });
